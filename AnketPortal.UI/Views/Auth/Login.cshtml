@{
    // Bu sayfa giriş sayfası olduğu için Master Page (Layout) kullanılmasın
    Layout = null;
}

<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Giriş Yap - Anket Portalı</title>
    <!-- Bootstrap 5 CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- FontAwesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">
    <style>
        body {
            background: #4e73df;
            height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            font-family: 'Segoe UI', sans-serif;
        }

        .login-card {
            background: white;
            border-radius: 1rem;
            box-shadow: 0 0.5rem 1rem rgba(0, 0, 0, 0.15);
            overflow: hidden;
            width: 100%;
            max-width: 900px;
        }

        .login-image {
            background: url('https://source.unsplash.com/600x800/?survey,analysis') center center;
            background-size: cover;
            height: 100%;
            min-height: 400px;
        }
    </style>
</head>
<body>

    <div class="container">
        <div class="login-card row mx-auto">
            <!-- Sol Taraf (Resim) -->
            <div class="col-lg-6 d-none d-lg-block p-0">
                <div class="login-image"></div>
            </div>
            <!-- Sağ Taraf (Form) -->
            <div class="col-lg-6 p-5">
                <div class="text-center mb-4">
                    <h1 class="h4 text-gray-900 mb-2 fw-bold"><i class="fa-solid fa-square-poll-vertical text-primary"></i> Anket Portalı</h1>
                    <p class="text-muted">Hoş geldiniz, devam etmek için giriş yapın.</p>
                </div>

                <!-- DİKKAT: Sayfa yenilenmesin diye onsubmit="return false;" ekledik! -->
                <form id="frmLogin" onsubmit="return false;">
                    <div class="mb-3">
                        <label class="form-label text-muted small fw-bold">Kullanıcı Adı</label>
                        <input type="text" class="form-control form-control-user rounded-pill p-3" id="txtUserName" placeholder="Kullanıcı adınızı girin" required>
                    </div>
                    <div class="mb-4">
                        <label class="form-label text-muted small fw-bold">Şifre</label>
                        <input type="password" class="form-control form-control-user rounded-pill p-3" id="txtPassword" placeholder="Şifreniz" required>
                    </div>

                    <!-- DİKKAT: Butonun tipini "button" yaptık ki asla sayfayı yenilemesin! -->
                    <button type="button" class="btn btn-primary w-100 rounded-pill p-3 fw-bold shadow-sm" id="btnSubmit">
                        <i class="fa-solid fa-right-to-bracket me-2"></i> Giriş Yap
                    </button>
                </form>

                <hr class="my-4">
                <div class="text-center">
                    <!-- BURASI GÜNCELLENDİ: Kayıt sayfasına doğru yönlendirme -->
                    <a class="small text-decoration-none fw-bold" href="/Auth/Register">Hesap Oluştur!</a>
                </div>
            </div>
        </div>
    </div>

    <!-- Jquery ve SweetAlert2 Kütüphaneleri -->
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <!-- AJAX İŞLEMLERİ -->
    <script>
        // 1. TOKEN ÇÖZÜCÜ FONKSİYON
        function parseJwt(token) {
            try {
                if(!token || token === "undefined" || token === "null") return null;
                var base64Url = token.split('.')[1];
                var base64 = base64Url.replace(/-/g, '+').replace(/_/g, '/');
                var jsonPayload = decodeURIComponent(window.atob(base64).split('').map(function(c) {
                    return '%' + ('00' + c.charCodeAt(0).toString(16)).slice(-2);
                }).join(''));
                return JSON.parse(jsonPayload);
            } catch (e) {
                console.error("Token parçalanamadı:", e);
                return null;
            }
        }

        $(document).ready(function () {

            // 2. SAYFA YÜKLENDİĞİNDE: BOZUK TOKEN KONTROLÜ (Geri sekmeyi engeller)
            var existingToken = localStorage.getItem("token");

            // Eğer "[object Object]" gibi bozuk bir veri kaydedilmişse hemen sil
            if (existingToken && existingToken.length < 30) {
                localStorage.removeItem("token");
            }
            // Eğer gerçek ve uzun bir token varsa anında yönlendir
            else if (existingToken && existingToken.length > 50) {
                var dToken = parseJwt(existingToken);
                if (dToken) {
                    var currentRole = dToken["http://schemas.microsoft.com/ws/2008/06/identity/claims/role"] || dToken.role || dToken.Role || "User";
                    if(currentRole === "Admin" || currentRole === "SuperAdmin") {
                        window.location.replace("/Home/Dashboard");
                    } else {
                        window.location.replace("/Home/Index");
                    }
                    return;
                }
            }

            // 3. GİRİŞ YAP BUTONUNA TIKLANDIĞINDA
            $("#btnSubmit").click(function () {
                var btn = $(this);
                var userName = $("#txtUserName").val().trim();
                var password = $("#txtPassword").val().trim();

                if(!userName || !password){
                    Swal.fire('Eksik Bilgi', 'Lütfen kullanıcı adı ve şifreyi doldurun.', 'warning');
                    return;
                }

                // Butonu Kilitler
                btn.prop("disabled", true).html('<i class="fas fa-spinner fa-spin me-2"></i> Giriş Yapılıyor...');

                $.ajax({
                    url: "https://localhost:7094/api/Auth/Login",
                    type: "POST",
                    contentType: "application/json",
                    data: JSON.stringify({ UserName: userName, Password: password }),
                    success: function (res) {

                        // 1. API Durumunu Kontrol Et (Büyük/Küçük harf duyarlılığı için ikisine de bakıyoruz)
                        var isSuccess = res.status === true || res.Status === true;
                        var msg = res.message || res.Message || "İşlem durumu anlaşılamadı.";

                        // 2. İŞTE TOKEN AVCISI: API token'ı nerede saklıyor bulalım!
                        var jwtToken = null;
                        var rData = res.data || res.Data;

                        if (rData) {
                            if (typeof rData === 'string') {
                                jwtToken = rData; // Bazen token direkt data'nın kendisi olur
                            } else {
                                // Token'ın farklı isimlendirmelerini ara
                                jwtToken = rData.token || rData.Token || rData.accessToken || rData.AccessToken;
                            }
                        }

                        // Belki de data nesnesi içinde değil, direkt ana nesnededir
                        if (!jwtToken) {
                            jwtToken = res.token || res.Token || res.accessToken || res.AccessToken;
                        }

                        // BAŞARILI GİRİŞ (Hem API başarılı dedi, hem de Token bulunduysa)
                        if (isSuccess && jwtToken && jwtToken.length > 20) {

                            // Token'ı kaydet
                            localStorage.setItem("token", jwtToken);

                            // Rolü bul
                            var decodedToken = parseJwt(jwtToken);
                            var role = "User";
                            if (decodedToken) {
                                role = decodedToken["http://schemas.microsoft.com/ws/2008/06/identity/claims/role"] || decodedToken.role || decodedToken.Role || "User";
                            }

                            // YÖNLENDİR
                            Swal.fire({
                                icon: 'success',
                                title: 'Giriş Başarılı!',
                                text: 'Sisteme yönlendiriliyorsunuz...',
                                timer: 1000,
                                showConfirmButton: false
                            }).then(function() {
                                if(role === "Admin" || role === "SuperAdmin") {
                                    window.location.replace("/Home/Dashboard");
                                } else {
                                    window.location.replace("/Home/Index");
                                }
                            });

                        }
                        // APİ BAŞARILI DEDİ AMA TOKEN GELMEDİ (GİZEMİ ÇÖZECEK KISIM)
                        else if (isSuccess && !jwtToken) {
                            Swal.fire({
                                icon: 'error',
                                title: 'Token Bulunamadı!',
                                text: 'API giriş başarılı dedi ama Token gelmedi. Lütfen F12 konsoluna bakın. Gelen Veri: ' + JSON.stringify(res)
                            });
                            console.log("Token Bulunamadı! API'den gelen tam yanıt:", res);
                            btn.prop("disabled", false).html('<i class="fa-solid fa-right-to-bracket me-2"></i> Giriş Yap');
                        }
                        // ŞİFRE YANLIŞ VEYA NORMAL HATA DURUMU
                        else {
                            Swal.fire('Hata', msg, 'error');
                            btn.prop("disabled", false).html('<i class="fa-solid fa-right-to-bracket me-2"></i> Giriş Yap');
                        }
                    },
                    error: function (xhr) {
                        var errorMsg = 'Bağlantı kurulamadı. Sunucu kapalı olabilir.';
                        if(xhr.responseJSON && xhr.responseJSON.message) {
                            errorMsg = xhr.responseJSON.message;
                        } else if (xhr.responseJSON && xhr.responseJSON.Message) {
                            errorMsg = xhr.responseJSON.Message;
                        }

                        Swal.fire('Hata!', errorMsg, 'error');
                        btn.prop("disabled", false).html('<i class="fa-solid fa-right-to-bracket me-2"></i> Giriş Yap');
                    }
                });
            });

            // Şifre kutusunda Enter'a basıldığında da tetiklensin
            $("#txtPassword").keypress(function (e) {
                if (e.which == 13) $("#btnSubmit").click();
            });
        });
    </script>
</body>
</html>