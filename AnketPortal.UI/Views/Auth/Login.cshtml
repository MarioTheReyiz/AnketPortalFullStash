@{
    // Bu sayfa giriş sayfası olduğu için Master Page (Layout) kullanılmasın
    Layout = null;
}

<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Giriş Yap - Anket Portalı</title>
    <!-- Bootstrap 5 CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- FontAwesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">
    <style>
        body {
            background: #4e73df;
            height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            font-family: 'Segoe UI', sans-serif;
        }

        .login-card {
            background: white;
            border-radius: 1rem;
            box-shadow: 0 0.5rem 1rem rgba(0, 0, 0, 0.15);
            overflow: hidden;
            width: 100%;
            max-width: 900px;
        }

        .login-image {
            background: url('https://source.unsplash.com/600x800/?survey,analysis') center center;
            background-size: cover;
            height: 100%;
            min-height: 400px;
        }
    </style>
</head>
<body>

    <div class="container">
        <div class="login-card row mx-auto">
            <!-- Sol Taraf (Resim) -->
            <div class="col-lg-6 d-none d-lg-block p-0">
                <div class="login-image"></div>
            </div>
            <!-- Sağ Taraf (Form) -->
            <div class="col-lg-6 p-5">
                <div class="text-center mb-4">
                    <h1 class="h4 text-gray-900 mb-2 fw-bold"><i class="fa-solid fa-square-poll-vertical text-primary"></i> Anket Portalı</h1>
                    <p class="text-muted">Hoş geldiniz, devam etmek için giriş yapın.</p>
                </div>

                <!-- DİKKAT: Sayfa yenilenmesin diye onsubmit="return false;" ekledik! -->
                <form id="frmLogin" onsubmit="return false;">
                    <div class="mb-3">
                        <label class="form-label text-muted small fw-bold">Kullanıcı Adı</label>
                        <input type="text" class="form-control form-control-user rounded-pill p-3" id="txtUserName" placeholder="Kullanıcı adınızı girin" required>
                    </div>
                    <div class="mb-4">
                        <label class="form-label text-muted small fw-bold">Şifre</label>
                        <input type="password" class="form-control form-control-user rounded-pill p-3" id="txtPassword" placeholder="Şifreniz" required>
                    </div>

                    <!-- DİKKAT: Butonun tipini "button" yaptık ki asla sayfayı yenilemesin! -->
                    <button type="button" class="btn btn-primary w-100 rounded-pill p-3 fw-bold shadow-sm" id="btnSubmit">
                        <i class="fa-solid fa-right-to-bracket me-2"></i> Giriş Yap
                    </button>
                </form>

                <hr class="my-4">
                <div class="text-center">
                    <a class="small text-decoration-none fw-bold" href="/Auth/Register">Hesap Oluştur!</a>
                </div>
            </div>
        </div>
    </div>

    <!-- Jquery ve SweetAlert2 Kütüphaneleri (Bunlar olmazsa AJAX çalışmaz!) -->
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <!-- AJAX İŞLEMLERİ -->
    <script>
        $(document).ready(function () {

            // Kullanıcı zaten giriş yapmışsa direkt Ana Sayfaya gönder
            if (localStorage.getItem("token")) {
                window.location.href = "/Home/Index";
            }

            // Butona tıklandığında (Sayfa yenilenme riski SIFIR)
            $("#btnSubmit").click(function () {

                var userName = $("#txtUserName").val();
                var password = $("#txtPassword").val();

                // Eğer alanlar boşsa uyarı ver
                if(!userName || !password){
                    Swal.fire('Eksik Bilgi', 'Lütfen kullanıcı adı ve şifreyi doldurun.', 'warning');
                    return;
                }

                // Butonu pasife al (Bekleniyor...)
                $("#btnSubmit").prop("disabled", true).html('<i class="fas fa-spinner fa-spin me-2"></i> Bekleniyor...');

                // API'ye İstek At
                $.ajax({
                    url: "https://localhost:7094/api/Auth/Login",
                    type: "POST",
                    contentType: "application/json",
                    data: JSON.stringify({ UserName: userName, Password: password }),
                    success: function (response) {
                        if (response.status) {
                            // Token'ı kaydet
                            localStorage.setItem("token", response.message);

                            Swal.fire({
                                icon: 'success',
                                title: 'Giriş Başarılı',
                                text: 'Yönlendiriliyorsunuz...',
                                showConfirmButton: false,
                                timer: 1500
                            }).then(() => {
                                window.location.href = "/Home/Index"; // Başarılıysa Home'a git
                            });
                        } else {
                            Swal.fire('Hata!', response.message, 'error');
                            $("#btnSubmit").prop("disabled", false).html('<i class="fa-solid fa-right-to-bracket me-2"></i> Giriş Yap');
                        }
                    },
                    error: function (xhr) {
                        console.log(xhr.responseText);
                        Swal.fire('Bağlantı veya Yetki Hatası!', 'Giriş yapılamadı. Kullanıcı adı veya şifre yanlış.', 'error');
                        $("#btnSubmit").prop("disabled", false).html('<i class="fa-solid fa-right-to-bracket me-2"></i> Giriş Yap');
                    }
                });
            });
        });
    </script>
</body>
</html>