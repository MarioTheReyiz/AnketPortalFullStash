@{
    ViewData["Title"] = "Şifremi Unuttum";
    Layout = null; 
}

<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Şifremi Unuttum - Anket Portalı</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">
    <style>
        body {
            background: #4e73df;
            height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            font-family: 'Segoe UI', sans-serif;
        }

        .forgot-card {
            background: white;
            border-radius: 1rem;
            box-shadow: 0 0.5rem 1rem rgba(0, 0, 0, 0.15);
            width: 100%;
            max-width: 500px;
            padding: 3rem 2rem;
        }

            .forgot-card h1 {
                font-size: 1.75rem;
                font-weight: 700;
                color: #1a1a2e;
            }
    </style>
</head>
<body>
    <div class="forgot-card">
        <div class="text-center mb-4">
            <h1>Şifrenizi mi Unuttunuz?</h1>
            <p class="text-muted">E-posta adresinizi girin, size sıfırlama bağlantısı gönderelim.</p>
        </div>

        <form id="frmForgot" onsubmit="return false;">
            <div class="mb-3">
                <label class="form-label fw-bold">E-Posta Adresi</label>
                <input type="email" class="form-control rounded-pill p-3" id="txtEmail" placeholder="ornek@mail.com" required>
            </div>
            <button type="button" class="btn btn-primary w-100 rounded-pill p-3 fw-bold shadow-sm" id="btnSend">
                <i class="fa-solid fa-paper-plane me-2"></i> Gönder
            </button>
        </form>

        <div id="divResult" class="mt-3"></div>

        <div class="text-center mt-4">
            <a href="/Auth/Login" class="text-decoration-none fw-bold"><i class="fa-solid fa-arrow-left me-1"></i> Giriş Sayfasına Dön</a>
        </div>
    </div>

    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        $(document).ready(function () {
            $("#btnSend").click(function () {
                var email = $("#txtEmail").val().trim();
                if (!email) {
                    Swal.fire('Uyarı', 'Lütfen e-posta adresinizi girin.', 'warning');
                    return;
                }

                var btn = $(this);
                btn.prop("disabled", true).html('<i class="fas fa-spinner fa-spin me-2"></i> Gönderiliyor...');

                $.ajax({
                    url: "https://localhost:7094/api/Auth/ForgotPassword",
                    type: "POST",
                    contentType: "application/json",
                    data: JSON.stringify({ Email: email }),
                    success: function (res) {
                        btn.prop("disabled", false).html('<i class="fa-solid fa-paper-plane me-2"></i> Gönder');
                        if (res.status || res.Status) {
                            $("#divResult").html('<div class="alert alert-success"><i class="fa-solid fa-circle-check me-2"></i> ' + (res.message || res.Message) + '</div>');
                        } else {
                            $("#divResult").html('<div class="alert alert-danger"><i class="fa-solid fa-circle-exclamation me-2"></i> ' + (res.message || res.Message || 'Bir hata oluştu.') + '</div>');
                        }
                    },
                    error: function () {
                        btn.prop("disabled", false).html('<i class="fa-solid fa-paper-plane me-2"></i> Gönder');
                        $("#divResult").html('<div class="alert alert-danger">Sunucuya ulaşılamadı.</div>');
                    }
                });
            });
        });
    </script>
</body>
</html>