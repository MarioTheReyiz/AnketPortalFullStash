<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Anket Portalı</title>

    <!-- Bootstrap 5 CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- FontAwesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">

    <style>
        body {
            background-color: #f8f9fc;
            overflow-x: hidden;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }

        .wrapper {
            display: flex;
            width: 100vw;
            height: 100vh;
        }

        .sidebar {
            width: 250px;
            background: #4e73df;
            color: white;
            transition: all 0.3s;
            display: flex;
            flex-direction: column;
        }

            .sidebar .brand {
                padding: 20px;
                font-size: 1.5rem;
                font-weight: bold;
                border-bottom: 1px solid rgba(255,255,255,.1);
                text-align: center;
                letter-spacing: 2px;
            }

            .sidebar a {
                color: rgba(255,255,255,.8);
                text-decoration: none;
                padding: 15px 20px;
                display: block;
                border-bottom: 1px solid rgba(255,255,255,.1);
                font-weight: 500;
            }

                .sidebar a:hover, .sidebar a.active {
                    color: #fff;
                    background: rgba(255,255,255,.2);
                    border-left: 4px solid #fff;
                }

        .main-content {
            flex-grow: 1;
            display: flex;
            flex-direction: column;
            overflow-y: auto;
        }

        .topbar {
            background: #fff;
            height: 70px;
            box-shadow: 0 .15rem 1.75rem 0 rgba(58,59,69,.15);
            display: flex;
            align-items: center;
            padding: 0 25px;
            justify-content: space-between;
            z-index: 10;
        }

        .content {
            padding: 25px;
            flex-grow: 1;
        }
    </style>

    <!-- YENİ: Alt sayfalardan gelen özel CSS'leri (Örn: Bayraklı telefon) buraya basacak -->
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>

    <div class="wrapper">
        <nav class="sidebar">
            <div class="brand"><i class="fa-solid fa-square-poll-vertical"></i> ANKET API</div>
            <a href="/Home/Index" id="navHome"><i class="fa-solid fa-house me-2"></i> Ana Sayfa</a>
            <a href="/Survey/Index" id="navSurveys"><i class="fa-solid fa-list-check me-2"></i> Tüm Anketler</a>

            <div id="adminMenu" style="display:none;">
                <div class="px-3 pt-3 pb-1 text-uppercase text-white-50" style="font-size: 0.75rem;">Yönetici Alanı</div>
                <a href="/Survey/Manage"><i class="fa-solid fa-gear me-2"></i> Anket Yönetimi</a>
            </div>

            <div id="superAdminMenu" style="display:none;">
                <a href="/Home/Users"><i class="fa-solid fa-users-gear me-2"></i> Kullanıcı Yönetimi</a>
            </div>

            <a href="#" id="btnLogout" class="mt-auto bg-danger text-white border-0"><i class="fa-solid fa-right-from-bracket me-2"></i> Çıkış Yap</a>
        </nav>

        <div class="main-content">
            <header class="topbar">
                <h4 class="m-0 text-secondary fw-bold" id="pageTitle">@ViewData["Title"]</h4>

                <a href="/Home/Profile" class="d-flex align-items-center text-decoration-none p-2 rounded" style="cursor: pointer;">
                    <div class="text-end me-3">
                        <button id="btnDarkModeToggle" class="btn btn-sm btn-outline-secondary rounded-circle me-3" title="Karanlık/Aydınlık Tema">
                            <i class="fa-solid fa-moon" id="iconTheme"></i>
                        </button>
                        <span class="d-block fw-bold text-dark" id="lblUserName">Kullanıcı Bekleniyor...</span>
                        <span class="badge bg-primary" id="lblUserRole">Yetki Yok</span>
                    </div>
                    <img class="img-profile rounded-circle shadow-sm border border-2 border-primary object-fit-cover" src="https://ui-avatars.com/api/?name=U&background=4e73df&color=fff" width="45" height="45" id="imgUserAvatar">
                </a>
            </header>

            <main class="content">
                @RenderBody()
            </main>
        </div>
    </div>

    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <script>
        function parseJwt(token) {
            try {
                var base64Url = token.split('.')[1];
                var base64 = base64Url.replace(/-/g, '+').replace(/_/g, '/');
                var jsonPayload = decodeURIComponent(window.atob(base64).split('').map(function(c) {
                    return '%' + ('00' + c.charCodeAt(0).toString(16)).slice(-2);
                }).join(''));
                return JSON.parse(jsonPayload);
            } catch (e) {
                return null;
            }
        }

        $(document).ready(function () {
                    // --- DARK MODE MANTIĞI ---
        var isDark = localStorage.getItem("theme") === "dark";

        // Sayfa ilk yüklendiğinde hafızadaki temayı uygula
        if (isDark) {
            $("body").addClass("dark-mode");
            $("#iconTheme").removeClass("fa-moon").addClass("fa-sun text-warning");
        }

        // Butona tıklandığında temayı değiştir ve hafızaya kaydet
        $("#btnDarkModeToggle").click(function () {
            $("body").toggleClass("dark-mode");
            var currentlyDark = $("body").hasClass("dark-mode");

            if (currentlyDark) {
                localStorage.setItem("theme", "dark");
                $("#iconTheme").removeClass("fa-moon").addClass("fa-sun text-warning");
            } else {
                localStorage.setItem("theme", "light");
                $("#iconTheme").removeClass("fa-sun text-warning").addClass("fa-moon");
            }
        });
            var token = localStorage.getItem("token");
            if (!token) {
                if (window.location.pathname.toLowerCase() !== "/auth/login" && window.location.pathname.toLowerCase() !== "/auth/register") {
                    window.location.href = "/Auth/Login";
                }
            } else {
                var decodedToken = parseJwt(token);
                if(decodedToken) {
                    var userName = decodedToken.FullName || decodedToken["FullName"] || decodedToken.unique_name || "Kullanıcı";
                    var userRole = decodedToken["http://schemas.microsoft.com/ws/2008/06/identity/claims/role"] || decodedToken.role || decodedToken.Role || "User";

                    $("#lblUserName").text(userName.toUpperCase());
                    $("#lblUserRole").text(userRole);

                    // Varsayılan avatarı oluştur
                    var firstLetter = userName.charAt(0).toUpperCase();
                    var defaultAvatar = "https://ui-avatars.com/api/?name=" + firstLetter + "&background=4e73df&color=fff&bold=true";
                    $("#imgUserAvatar").attr("src", defaultAvatar);

                    // Profil fotosu varsa arka planda çekip sağ üste bas
                    $.ajax({
                        url: "https://localhost:7094/api/Auth/GetProfile",
                        type: "GET",
                        headers: { "Authorization": "Bearer " + token },
                        success: function(res) {
                            if (res.status && res.data && res.data.profilePhoto && res.data.profilePhoto.length > 50) {
                                $("#imgUserAvatar").attr("src", res.data.profilePhoto);
                            }
                        }
                    });

                    if(userRole === "Admin" || userRole === "SuperAdmin") {
                        $("#adminMenu").show();
                        $("#lblUserRole").removeClass("bg-primary").addClass("bg-danger");
                    }
                    if(userRole === "SuperAdmin") {
                        $("#superAdminMenu").show();
                        $("#lblUserRole").removeClass("bg-danger").addClass("bg-dark");
                    }
                }
            }

            $("#btnLogout").click(function(e) {
                e.preventDefault();
                Swal.fire({
                    title: 'Çıkış Yapılıyor', text: "Emin misiniz?", icon: 'warning', showCancelButton: true, confirmButtonText: 'Evet', cancelButtonText: 'İptal'
                }).then((result) => {
                    if (result.isConfirmed) {
                        localStorage.clear();
                        window.location.href = "/Auth/Login";
                    }
                });
            });
        });
    </script>

    <!-- YENİ: Alt sayfalardan gelen özel JS'leri buraya basacak. HATA BURANIN EKSİKLİĞİNDEN ÇIKIYORDU! -->
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>