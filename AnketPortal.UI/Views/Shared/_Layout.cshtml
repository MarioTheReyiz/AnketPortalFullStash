<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Anket Portalı</title>

    <!-- Bootstrap 5 CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- FontAwesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">

    <style>
        body {
            background-color: #f8f9fc;
            overflow-x: hidden;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            transition: background-color 0.3s, color 0.3s;
        }

        .wrapper {
            display: flex;
            width: 100vw;
            height: 100vh;
        }

        .sidebar {
            width: 250px;
            background: #4e73df;
            color: white;
            transition: all 0.3s;
            display: flex;
            flex-direction: column;
        }

            .sidebar .brand {
                padding: 20px;
                font-size: 1.5rem;
                font-weight: bold;
                border-bottom: 1px solid rgba(255,255,255,.1);
                text-align: center;
                letter-spacing: 2px;
            }

            .sidebar a {
                color: rgba(255,255,255,.8);
                text-decoration: none;
                padding: 15px 20px;
                display: block;
                border-bottom: 1px solid rgba(255,255,255,.1);
                font-weight: 500;
            }

                .sidebar a:hover, .sidebar a.active {
                    color: #fff;
                    background: rgba(255,255,255,.2);
                    border-left: 4px solid #fff;
                }

        .main-content {
            flex-grow: 1;
            display: flex;
            flex-direction: column;
            overflow-y: auto;
        }

        .topbar {
            background: #fff;
            height: 70px;
            box-shadow: 0 .15rem 1.75rem 0 rgba(58,59,69,.15);
            display: flex;
            align-items: center;
            padding: 0 25px;
            justify-content: space-between;
            z-index: 10;
            transition: background-color 0.3s;
        }

        .content {
            padding: 25px;
            flex-grow: 1;
        }

        /* KUSURSUZ DARK MODE CSS KODLARI */
        body.dark-mode {
            background-color: #121212 !important;
            color: #e0e0e0 !important;
        }

            body.dark-mode .sidebar {
                background: #1a1c23 !important;
                border-right: 1px solid #333;
            }

            body.dark-mode .topbar {
                background: #1f2937 !important;
                border-bottom: 1px solid #333;
            }

            body.dark-mode .card, body.dark-mode .bg-white {
                background-color: #1f2937 !important;
                border-color: #333 !important;
            }

            body.dark-mode .card-header {
                background-color: #283046 !important;
                border-bottom: 1px solid #333 !important;
            }

            body.dark-mode .text-gray-800, body.dark-mode .text-dark {
                color: #e0e0e0 !important;
            }

            body.dark-mode .table, body.dark-mode .table td, body.dark-mode .table th {
                color: #e0e0e0 !important;
                border-color: #333 !important;
                background-color: transparent !important;
            }

                body.dark-mode .table-light, body.dark-mode .table thead th {
                    background-color: #283046 !important;
                    color: #fff !important;
                    border-bottom: 2px solid #444 !important;
                }

            body.dark-mode .table-hover > tbody > tr:hover > td, body.dark-mode .table-hover > tbody > tr:hover > th {
                background-color: #2c344a !important;
                color: #fff !important;
            }

            body.dark-mode .modal-content {
                background-color: #1f2937 !important;
                color: #e0e0e0;
                border: 1px solid #444;
            }

            body.dark-mode .modal-header {
                border-bottom: 1px solid #333;
            }

            body.dark-mode .modal-footer {
                border-top: 1px solid #333;
            }

            body.dark-mode input.form-control, body.dark-mode textarea.form-control, body.dark-mode select.form-select {
                background-color: #374151 !important;
                color: #fff !important;
                border: 1px solid #4b5563 !important;
            }

            body.dark-mode .input-group-text {
                background-color: #283046 !important;
                color: #aaa;
                border: 1px solid #4b5563 !important;
            }

            body.dark-mode .text-muted {
                color: #9ca3af !important;
            }

            body.dark-mode .dropdown-menu {
                background-color: #1f2937 !important;
                border: 1px solid #333 !important;
            }

            body.dark-mode .dropdown-item {
                color: #e0e0e0 !important;
            }

                body.dark-mode .dropdown-item:hover {
                    background-color: #2c344a !important;
                    color: #fff !important;
                }

                body.dark-mode .dropdown-item .text-dark {
                    color: #e0e0e0 !important;
                }

            body.dark-mode .dropdown-header {
                background-color: #283046 !important;
                border-bottom: 1px solid #333;
            }

            body.dark-mode .border-bottom {
                border-color: #333 !important;
            }
    </style>
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>

    <div class="wrapper">
        <nav class="sidebar">
            <div class="brand"><i class="fa-solid fa-square-poll-vertical"></i> ANKET API</div>
            <a href="/Home/Index" id="navHome"><i class="fa-solid fa-house me-2"></i> Ana Sayfa</a>

            <div id="adminMenu" style="display:none;">
                <div class="px-3 pt-3 pb-1 text-uppercase text-white-50" style="font-size: 0.75rem;">Yönetici Alanı</div>
                <a href="/Survey/Index"><i class="fa-solid fa-gear me-2"></i> Anket Yönetimi</a>
                <a href="/Home/Reviews"><i class="fa-solid fa-gear me-2"></i> Değerlendirmeler</a>
            </div>

            <div id="superAdminMenu" style="display:none;">
                <a href="/Home/Users"><i class="fa-solid fa-users-gear me-2"></i> Kullanıcı Yönetimi</a>
                <a href="/Home/SystemLogs"><i class="fa-solid fa-server me-2"></i> Sistem Logları</a>
            </div>

            <a href="#" id="btnLogout" class="mt-auto bg-danger text-white border-0"><i class="fa-solid fa-right-from-bracket me-2"></i> Çıkış Yap</a>
        </nav>

        <div class="main-content">
            <header class="topbar">
                <h4 class="m-0 text-secondary fw-bold" id="pageTitle">@ViewData["Title"]</h4>

                <div class="d-flex align-items-center">

                    <!-- BİLDİRİM ÇANI -->
                    <div class="dropdown me-3">
                        <button class="btn btn-sm btn-outline-secondary rounded-circle position-relative border-0" type="button" id="notificationDropdown" data-bs-toggle="dropdown" aria-expanded="false" title="Bildirimler">
                            <i class="fa-solid fa-bell fs-5 text-gray-800"></i>
                            <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger border border-light" style="font-size: 0.60rem; padding: 0.25em 0.4em; display:none;" id="notificationCount">
                                0
                            </span>
                        </button>
                        <ul class="dropdown-menu dropdown-menu-end shadow border-0 mt-2" aria-labelledby="notificationDropdown" style="width: 300px;">
                            <li class="dropdown-header bg-primary text-white fw-bold py-2 rounded-top">Bildirim Merkezi</li>

                            <!-- BİLDİRİMLER AJAX İLE BURAYA GELECEK -->
                            <div id="notificationList" style="max-height: 300px; overflow-y: auto;">
                                <div class="text-center py-3 text-muted"><i class="fas fa-spinner fa-spin"></i> Yükleniyor...</div>
                            </div>

                            <li><a class="dropdown-item text-center small text-muted bg-light py-2 fw-bold" href="#" id="btnReadAll"><i class="fa-solid fa-check-double me-1"></i> Tümünü Okundu İşaretle</a></li>
                        </ul>
                    </div>
                    <!-- BİLDİRİM ÇANI BİTİŞ -->
                    <!-- DARK MODE BUTONU -->
                    <button id="btnDarkModeToggle" class="btn btn-sm btn-outline-secondary rounded-circle me-3 border-0" title="Karanlık/Aydınlık Tema">
                        <i class="fa-solid fa-moon fs-5 text-gray-800" id="iconTheme"></i>
                    </button>

                    <a href="/Home/Profile" class="d-flex align-items-center text-decoration-none p-2 rounded" style="cursor: pointer;">
                        <div class="text-end me-3">
                            <span class="d-block fw-bold text-dark" id="lblUserName">Yükleniyor...</span>
                            <span class="badge bg-primary" id="lblUserRole">Yetki Yok</span>
                        </div>
                        <img class="img-profile rounded-circle shadow-sm border border-2 border-primary object-fit-cover" src="https://ui-avatars.com/api/?name=U&background=4e73df&color=fff" width="45" height="45" id="imgUserAvatar">
                    </a>
                </div>
            </header>

            <main class="content">
                @RenderBody()
            </main>
        </div>
    </div>

    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <script>
        // --- DARK MODE MANTIĞI ---
        var isDark = localStorage.getItem("theme") === "dark";

        if (isDark) {
            $("body").addClass("dark-mode");
            $("#iconTheme").removeClass("fa-moon").addClass("fa-sun text-warning");
        }

        $("#btnDarkModeToggle").click(function (e) {
            e.preventDefault();
            $("body").toggleClass("dark-mode");
            var currentlyDark = $("body").hasClass("dark-mode");

            if (currentlyDark) {
                localStorage.setItem("theme", "dark");
                $("#iconTheme").removeClass("fa-moon").addClass("fa-sun text-warning");
            } else {
                localStorage.setItem("theme", "light");
                $("#iconTheme").removeClass("fa-sun text-warning").addClass("fa-moon");
            }
        });

        function parseJwt(token) {
            try {
                var base64Url = token.split('.')[1];
                var base64 = base64Url.replace(/-/g, '+').replace(/_/g, '/');
                var jsonPayload = decodeURIComponent(window.atob(base64).split('').map(function(c) {
                    return '%' + ('00' + c.charCodeAt(0).toString(16)).slice(-2);
                }).join(''));
                return JSON.parse(jsonPayload);
            } catch (e) {
                return null;
            }
        }

        $(document).ready(function () {
            var token = localStorage.getItem("token");

            if (!token) {
                if (window.location.pathname.toLowerCase() !== "/auth/login" && window.location.pathname.toLowerCase() !== "/auth/register") {
                    window.location.href = "/Auth/Login";
                }
            } else {
                var decodedToken = parseJwt(token);
                if(decodedToken) {

                    var userRole = decodedToken["http://schemas.microsoft.com/ws/2008/06/identity/claims/role"] || decodedToken.role || decodedToken.Role || "User";
                    $("#lblUserRole").text(userRole);

                    var tempName = decodedToken.unique_name || decodedToken["http://schemas.xmlsoap.org/ws/2005/05/identity/claims/name"] || "Kullanıcı";
                    $("#lblUserName").text(tempName.toUpperCase());

                    var firstLetter = tempName.charAt(0).toUpperCase();
                    var defaultAvatar = "https://ui-avatars.com/api/?name=" + firstLetter + "&background=4e73df&color=fff&bold=true";
                    $("#imgUserAvatar").attr("src", defaultAvatar);

                    // Profil Bilgileri
                    $.ajax({
                        url: "https://localhost:7094/api/Auth/GetProfile",
                        type: "GET",
                        headers: { "Authorization": "Bearer " + token },
                        success: function(res) {
                            if (res.status && res.data) {
                                if(res.data.userName) {
                                    $("#lblUserName").text(res.data.userName.toUpperCase());
                                }
                                if(res.data.profilePhoto && res.data.profilePhoto.length > 50) {
                                    $("#imgUserAvatar").attr("src", res.data.profilePhoto);
                                } else {
                                    var realFirstLetter = (res.data.userName || "U").charAt(0).toUpperCase();
                                    $("#imgUserAvatar").attr("src", "https://ui-avatars.com/api/?name=" + realFirstLetter + "&background=4e73df&color=fff&bold=true");
                                }
                            }
                        },
                        error: function(xhr) {
                            if(xhr.status === 401) {
                                Swal.fire({
                                    icon: 'warning',
                                    title: 'Oturum Süresi Doldu',
                                    text: 'Lütfen güvenliğiniz için tekrar giriş yapın.',
                                    confirmButtonText: 'Giriş Yap'
                                }).then(() => {
                                    localStorage.removeItem("token");
                                    window.location.href = "/Auth/Login";
                                });
                            }
                        }
                    });

                    // =====================================================
                    // BUG FIX #2: BİLDİRİM SİSTEMİ
                    // Eski yöntem: sadece bildirim SAYISI kaydediliyordu.
                    // Sayfa yenilenince API yeni veri döndürdüğünde
                    // sayı eşleşmesi bozulup balonun tekrar çıkmasına
                    // yol açıyordu.
                    //
                    // Yeni yöntem: okunan her bildirimin benzersiz anahtarı
                    // (mesaj + zaman damgası) localStorage'a JSON dizisi
                    // olarak kaydedilir. Sayfa yenilense bile hangi
                    // bildirimlerin okunduğu hatırlanır.
                    // =====================================================
                    function getReadNotifKeys() {
                        try {
                            return JSON.parse(localStorage.getItem("readNotifKeys") || "[]");
                        } catch(e) {
                            return [];
                        }
                    }

                    function makeNotifKey(n) {
                        // Her bildirimi mesaj + zaman ile eşsiz tanımla
                        return (n.message || "") + "|" + (n.time || "");
                    }

                    function loadNotifications() {
                        $.ajax({
                            url: "https://localhost:7094/api/Survey/GetNotifications",
                            type: "GET",
                            headers: { "Authorization": "Bearer " + token },
                            success: function(res) {
                                if (res.status && res.data) {
                                    var notifs = res.data;
                                    var readKeys = getReadNotifKeys();

                                    // Kaç bildirim daha önce okunmadı?
                                    var unreadCount = notifs.filter(function(n) {
                                        return readKeys.indexOf(makeNotifKey(n)) === -1;
                                    }).length;

                                    if (unreadCount > 0) {
                                        $("#notificationCount").text(unreadCount).show();
                                    } else {
                                        $("#notificationCount").hide();
                                    }

                                    var html = "";
                                    if (notifs.length === 0) {
                                        html = '<li><span class="dropdown-item text-center text-muted py-3">Yeni bildiriminiz yok.</span></li>';
                                    } else {
                                        notifs.forEach(function(n) {
                                            var isRead = readKeys.indexOf(makeNotifKey(n)) !== -1;
                                            var readStyle = isRead ? "opacity: 0.55;" : "font-weight: bold;";
                                            html += `
                                                <li>
                                                    <a class="dropdown-item d-flex align-items-center py-3 border-bottom" href="#" style="${readStyle}">
                                                        <div class="me-3">
                                                            <div class="${n.color} rounded-circle d-flex align-items-center justify-content-center text-white" style="width: 40px; height: 40px;">
                                                                <i class="fa-solid ${n.icon}"></i>
                                                            </div>
                                                        </div>
                                                        <div>
                                                            <div class="small text-muted">${n.time}</div>
                                                            <span class="text-dark text-wrap" style="font-size: 0.85rem;">${n.message}</span>
                                                        </div>
                                                    </a>
                                                </li>
                                            `;
                                        });
                                    }

                                    $("#notificationList").html(html);

                                    // Tümünü Okundu İşaretle butonu
                                    $("#btnReadAll").off("click").on("click", function(e) {
                                        e.preventDefault();
                                        // Tüm bildirim anahtarlarını kaydet
                                        var allKeys = notifs.map(function(n) { return makeNotifKey(n); });
                                        localStorage.setItem("readNotifKeys", JSON.stringify(allKeys));
                                        $("#notificationCount").fadeOut();
                                        // Listedeki tüm öğeleri "okundu" görünümüne al
                                        $("#notificationList .dropdown-item").css("opacity", "0.55").css("font-weight", "normal");
                                    });
                                }
                            }
                        });
                    }

                    loadNotifications();

                    if(userRole === "Admin" || userRole === "SuperAdmin") {
                        $("#adminMenu").show();
                        $("#lblUserRole").removeClass("bg-primary").addClass("bg-danger");
                    }
                    if(userRole === "SuperAdmin") {
                        $("#superAdminMenu").show();
                        $("#lblUserRole").removeClass("bg-danger").addClass("bg-dark");
                    }
                }
            }

            $("#btnLogout").click(function(e) {
                e.preventDefault();
                Swal.fire({
                    title: 'Çıkış Yapılıyor', text: "Emin misiniz?", icon: 'warning', showCancelButton: true, confirmButtonText: 'Evet', cancelButtonText: 'İptal'
                }).then((result) => {
                    if (result.isConfirmed) {
                        localStorage.clear();
                        window.location.href = "/Auth/Login";
                    }
                });
            });
        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
