<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Anket Portalı</title>

    <!-- Bootstrap 5 CSS (Yönerge Şartı) -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- FontAwesome (İkonlar için) -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">

    <!-- Özel İskelet CSS'imiz -->
    <style>
        body { background-color: #f8f9fc; overflow-x: hidden; font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; }
        .wrapper { display: flex; width: 100vw; height: 100vh; }

        /* Sol Menü (Sidebar) */
        .sidebar { width: 250px; background: #4e73df; color: white; transition: all 0.3s; display: flex; flex-direction: column; }
        .sidebar .brand { padding: 20px; font-size: 1.5rem; font-weight: bold; border-bottom: 1px solid rgba(255,255,255,.1); text-align: center; letter-spacing: 2px; }
        .sidebar a { color: rgba(255,255,255,.8); text-decoration: none; padding: 15px 20px; display: block; border-bottom: 1px solid rgba(255,255,255,.1); font-weight: 500; }
        .sidebar a:hover, .sidebar a.active { color: #fff; background: rgba(255,255,255,.2); border-left: 4px solid #fff; }

        /* Sağ İçerik Alanı */
        .main-content { flex-grow: 1; display: flex; flex-direction: column; overflow-y: auto; }

        /* Üst Bar (Topbar) */
        .topbar { background: #fff; height: 70px; box-shadow: 0 .15rem 1.75rem 0 rgba(58,59,69,.15); display: flex; align-items: center; padding: 0 25px; justify-content: space-between; z-index: 10;}
        .content { padding: 25px; flex-grow: 1; }
    </style>
</head>
<body>

    <div class="wrapper">
        <!-- SOL MENÜ -->
        <nav class="sidebar">
            <div class="brand">
                <i class="fa-solid fa-square-poll-vertical"></i> ANKET API
            </div>
            <a href="/Home/Index" id="navHome"><i class="fa-solid fa-house me-2"></i> Ana Sayfa</a>
            <a href="/Survey/Index" id="navSurveys"><i class="fa-solid fa-list-check me-2"></i> Tüm Anketler</a>

            <!-- Yöneticiye Özel Menü (Sadece Admin görecek şekilde JS ile yöneteceğiz) -->
            <div id="adminMenu" style="display:none;">
                <div class="px-3 pt-3 pb-1 text-uppercase text-white-50" style="font-size: 0.75rem;">Yönetici Alanı</div>
                <a href="/Survey/Manage"><i class="fa-solid fa-gear me-2"></i> Anket Yönetimi</a>
            </div>

            <!-- Çıkış Butonu (En Alta İter) -->
            <a href="#" id="btnLogout" class="mt-auto bg-danger text-white border-0"><i class="fa-solid fa-right-from-bracket me-2"></i> Çıkış Yap</a>
        </nav>

        <!-- SAĞ TARAF -->
        <div class="main-content">
            <!-- ÜST BAR -->
            <header class="topbar">
                <h4 class="m-0 text-secondary fw-bold" id="pageTitle">@ViewData["Title"]</h4>
                <div class="d-flex align-items-center">
                    <div class="text-end me-3">
                        <span class="d-block fw-bold text-dark" id="lblUserName">Kullanıcı Bekleniyor...</span>
                        <span class="badge bg-primary" id="lblUserRole">Yetki Yok</span>
                    </div>
                    <img class="img-profile rounded-circle shadow-sm" src="https://ui-avatars.com/api/?name=User&background=random&color=fff" width="45" height="45" id="imgUserAvatar">
                </div>
            </header>

            <!-- GÖVDE (DİNAMİK İÇERİK BURAYA GELECEK) -->
            <main class="content">
                @RenderBody()
            </main>
        </div>
    </div>

    <!-- Jquery (Yönergedeki AJAX zorunluluğu için) -->
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <!-- Bootstrap 5 JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <!-- SweetAlert2 (Hata/Başarı pop-up'ları için Senior dokunuşu) -->
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <!-- GÜVENLİK VE AJAX MİMARİSİ -->
    <!-- GÜVENLİK VE AJAX MİMARİSİ -->
    <script>
        // JWT Token'ı çözen (Decode eden) Senior fonksiyonumuz
        function parseJwt(token) {
            try {
                var base64Url = token.split('.')[1];
                var base64 = base64Url.replace(/-/g, '+').replace(/_/g, '/');
                var jsonPayload = decodeURIComponent(window.atob(base64).split('').map(function(c) {
                    return '%' + ('00' + c.charCodeAt(0).toString(16)).slice(-2);
                }).join(''));
                return JSON.parse(jsonPayload);
            } catch (e) {
                return null;
            }
        }

        $(document).ready(function () {
            // 1. JWT Token Kontrolü
            var token = localStorage.getItem("token");
            if (!token) {
                // Token yoksa ve Login/Register sayfasında değilsek dışarı at
                if (window.location.pathname.toLowerCase() !== "/auth/login" && window.location.pathname.toLowerCase() !== "/auth/register") {
                    window.location.href = "/Auth/Login";
                }
            } else {
                // TOKEN VARSA DECODE ET VE EKRANA YAZ!
                var decodedToken = parseJwt(token);
                if(decodedToken) {
                    // ASP.NET Core Identity'nin token içine koyduğu varsayılan Claim tipleri (İsim ve Rol)
                    var userName = decodedToken["http://schemas.xmlsoap.org/ws/2005/05/identity/claims/name"] || decodedToken.unique_name || "Kullanıcı";
                    var userRole = decodedToken["http://schemas.microsoft.com/ws/2008/06/identity/claims/role"] || decodedToken.role || "Üye";

                    // Sağ üst köşedeki yazıları güncelle
                    $("#lblUserName").text(userName.toUpperCase());
                    $("#lblUserRole").text(userRole);

                    // Profil resmini (Avatar) kullanıcının baş harflerine göre dinamik oluştur
                    $("#imgUserAvatar").attr("src", "https://ui-avatars.com/api/?name=" + userName + "&background=4e73df&color=fff&bold=true");

                    // ROL KONTROLÜ: Eğer Admin veya SuperAdmin ise Yönetici Menüsünü Göster!
                    if(userRole === "Admin" || userRole === "SuperAdmin") {
                        $("#adminMenu").show();
                        $("#lblUserRole").removeClass("bg-primary").addClass("bg-danger"); // Adminse rozeti kırmızı yap
                    }
                }
            }

            // 2. Çıkış Yapma İşlemi
            $("#btnLogout").click(function(e) {
                e.preventDefault();
                Swal.fire({
                    title: 'Çıkış Yapılıyor',
                    text: "Sistemden ayrılmak istediğinize emin misiniz?",
                    icon: 'warning',
                    showCancelButton: true,
                    confirmButtonColor: '#d33',
                    cancelButtonColor: '#3085d6',
                    confirmButtonText: 'Evet, Çıkış Yap',
                    cancelButtonText: 'İptal'
                }).then((result) => {
                    if (result.isConfirmed) {
                        localStorage.removeItem("token"); // Token'ı sil
                        window.location.href = "/Auth/Login"; // Login'e şutla
                    }
                });
            });
        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>