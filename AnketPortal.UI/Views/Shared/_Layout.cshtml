<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Anket Portalı</title>

    <!-- Bootstrap 5 CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- FontAwesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">

    <!-- Özel İskelet CSS -->
    <style>
        body {
            background-color: #f8f9fc;
            overflow-x: hidden;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }

        .wrapper {
            display: flex;
            width: 100vw;
            height: 100vh;
        }

        /* Sol Menü (Sidebar) */
        .sidebar {
            width: 250px;
            background: #4e73df;
            color: white;
            transition: all 0.3s;
            display: flex;
            flex-direction: column;
        }

            .sidebar .brand {
                padding: 20px;
                font-size: 1.5rem;
                font-weight: bold;
                border-bottom: 1px solid rgba(255,255,255,.1);
                text-align: center;
                letter-spacing: 2px;
            }

            .sidebar a {
                color: rgba(255,255,255,.8);
                text-decoration: none;
                padding: 15px 20px;
                display: block;
                border-bottom: 1px solid rgba(255,255,255,.1);
                font-weight: 500;
            }

                .sidebar a:hover, .sidebar a.active {
                    color: #fff;
                    background: rgba(255,255,255,.2);
                    border-left: 4px solid #fff;
                }

        /* Sağ İçerik Alanı */
        .main-content {
            flex-grow: 1;
            display: flex;
            flex-direction: column;
            overflow-y: auto;
        }

        /* Üst Bar (Topbar) */
        .topbar {
            background: #fff;
            height: 70px;
            box-shadow: 0 .15rem 1.75rem 0 rgba(58,59,69,.15);
            display: flex;
            align-items: center;
            padding: 0 25px;
            justify-content: space-between;
            z-index: 10;
        }

        .content {
            padding: 25px;
            flex-grow: 1;
        }
    </style>
</head>
<body>

    <div class="wrapper">
        <!-- SOL MENÜ -->
        <nav class="sidebar">
            <div class="brand">
                <i class="fa-solid fa-square-poll-vertical"></i> ANKET API
            </div>
            <a href="/Home/Index" id="navHome"><i class="fa-solid fa-house me-2"></i> Ana Sayfa</a>
            <a href="/Survey/Index" id="navSurveys"><i class="fa-solid fa-list-check me-2"></i> Tüm Anketler</a>

            <!-- Yöneticiye Özel Menü (Sadece Admin ve SuperAdmin görecek) -->
            <div id="adminMenu" style="display:none;">
                <div class="px-3 pt-3 pb-1 text-uppercase text-white-50" style="font-size: 0.75rem;">Yönetici Alanı</div>
                <a href="/Survey/Manage"><i class="fa-solid fa-gear me-2"></i> Anket Yönetimi</a>
            </div>

            <!-- SÜPER ADMİNE ÖZEL MENÜ -->
            <div id="superAdminMenu" style="display:none;">
                <a href="/Home/Users"><i class="fa-solid fa-users-gear me-2"></i> Kullanıcı Yönetimi</a>
            </div>

            <!-- Çıkış Butonu (En Alta İter) -->
            <a href="#" id="btnLogout" class="mt-auto bg-danger text-white border-0"><i class="fa-solid fa-right-from-bracket me-2"></i> Çıkış Yap</a>
        </nav>

        <!-- SAĞ TARAF -->
        <div class="main-content">
            <!-- ÜST BAR -->
            <!-- ÜST BAR -->
            <header class="topbar">
                <h4 class="m-0 text-secondary fw-bold" id="pageTitle">@ViewData["Title"]</h4>

                <!-- YENİ: Tıklanabilir Profil Alanı -->
                <a href="/Home/Profile" class="d-flex align-items-center text-decoration-none p-2 rounded" style="cursor: pointer; transition: 0.2s;">
                    <div class="text-end me-3">
                        <span class="d-block fw-bold text-dark" id="lblUserName">Kullanıcı Bekleniyor...</span>
                        <span class="badge bg-primary" id="lblUserRole">Yetki Yok</span>
                    </div>
                    <img class="img-profile rounded-circle shadow-sm border border-2 border-primary" src="https://ui-avatars.com/api/?name=U&background=4e73df&color=fff" width="45" height="45" id="imgUserAvatar">
                </a>
            </header>

            <!-- GÖVDE (DİNAMİK İÇERİK BURAYA GELECEK) -->
            <main class="content">
                @RenderBody()
            </main>
        </div>
    </div>

    <!-- Jquery -->
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <!-- Bootstrap 5 JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <!-- SweetAlert2 -->
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <!-- GÜVENLİK VE AJAX MİMARİSİ -->
    <script>
        // JWT Token'ı çözen fonksiyon
        function parseJwt(token) {
            try {
                var base64Url = token.split('.')[1];
                var base64 = base64Url.replace(/-/g, '+').replace(/_/g, '/');
                var jsonPayload = decodeURIComponent(window.atob(base64).split('').map(function(c) {
                    return '%' + ('00' + c.charCodeAt(0).toString(16)).slice(-2);
                }).join(''));
                return JSON.parse(jsonPayload);
            } catch (e) {
                return null;
            }
        }

        $(document).ready(function () {
            // 1. JWT Token Kontrolü
            var token = localStorage.getItem("token");
            if (!token) {
                if (window.location.pathname.toLowerCase() !== "/auth/login" && window.location.pathname.toLowerCase() !== "/auth/register") {
                    window.location.href = "/Auth/Login";
                }
            } else {
                var decodedToken = parseJwt(token);
                if(decodedToken) {
                   var userName = decodedToken.FullName
            || decodedToken["FullName"]
            || decodedToken["http://schemas.xmlsoap.org/ws/2005/05/identity/claims/name"]
            || decodedToken["http://schemas.xmlsoap.org/ws/2005/05/identity/claims/emailaddress"]
            || decodedToken.email
            || "KULLANICI";

                    var userRole = decodedToken["http://schemas.microsoft.com/ws/2008/06/identity/claims/role"]
                                || decodedToken.role
                                || decodedToken.Role
                                || "User";

                    // Sağ üst köşedeki yazıları güncelle
                    $("#lblUserName").text(userName.toUpperCase());
                    $("#lblUserRole").text(userRole);

                    // Profil resmini oluştur
                    var firstLetter = userName.charAt(0).toUpperCase();
                    $("#imgUserAvatar").attr("src", "https://ui-avatars.com/api/?name=" + firstLetter + "&background=4e73df&color=fff&bold=true");

                    // ROL KONTROLLERİ VE MENÜ GİZLE/GÖSTER
                    if(userRole === "Admin" || userRole === "SuperAdmin") {
                        $("#adminMenu").show();
                        $("#lblUserRole").removeClass("bg-primary").addClass("bg-danger");
                    }

                    // SADECE SUPERADMIN İÇİN KULLANICI YÖNETİMİ MENÜSÜNÜ AÇ
                    if(userRole === "SuperAdmin") {
                        $("#superAdminMenu").show();
                        $("#lblUserRole").removeClass("bg-danger").addClass("bg-dark"); // SuperAdmin rozetini siyah yapalım daha havalı dursun
                    }
                }
            }

            // 2. Çıkış Yapma İşlemi
            $("#btnLogout").click(function(e) {
                e.preventDefault();
                Swal.fire({
                    title: 'Çıkış Yapılıyor',
                    text: "Sistemden ayrılmak istediğinize emin misiniz?",
                    icon: 'warning',
                    showCancelButton: true,
                    confirmButtonColor: '#d33',
                    cancelButtonColor: '#3085d6',
                    confirmButtonText: 'Evet, Çıkış Yap',
                    cancelButtonText: 'İptal'
                }).then((result) => {
                    if (result.isConfirmed) {
                        localStorage.removeItem("token");
                        localStorage.removeItem("refreshToken"); // Bunu da silelim ki arkada kalmasın
                        window.location.href = "/Auth/Login";
                    }
                });
            });
        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>