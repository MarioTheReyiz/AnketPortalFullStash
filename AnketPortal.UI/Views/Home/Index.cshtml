@{
    ViewData["Title"] = "Ana Sayfa";
    Layout = "~/Views/Shared/_UserLayout.cshtml";
}

<div class="container-fluid mt-4">
    <!-- KAHRAMAN (HERO) BÖLÜMÜ -->
    <div class="row mb-5">
        <div class="col-12">
            <div class="card shadow-sm border-0 bg-primary text-white overflow-hidden position-relative" style="border-radius: 20px;">
                <div class="card-body p-5 position-relative" style="z-index: 2;">
                    <h2 class="fw-bold mb-3 display-5">Hoş Geldin, <span id="lblWelcomeName" class="text-warning">Kullanıcı</span>! 👋</h2>
                    <p class="fs-5 mb-0 opacity-75" style="max-width: 600px;">
                        Senin için hazırlanan anketlere katılarak süreçlerimize yön verebilir, sesini duyurabilirsin. Aşağıdaki aktif anketlerden hemen başla!
                    </p>
                </div>
                <i class="fa-solid fa-comments position-absolute text-white opacity-25" style="font-size: 18rem; right: -30px; bottom: -50px; z-index: 1;"></i>
            </div>
        </div>
    </div>

    <div class="d-sm-flex align-items-center justify-content-between mb-4">
        <h1 class="h4 mb-0 text-gray-800 fw-bold"><i class="fa-solid fa-list-check text-primary me-2"></i> Yayındaki Anketler</h1>
    </div>

    <!-- ANKET KARTLARI BURAYA GELECEK -->
    <div class="row" id="publicSurveysContainer">
        <div class="col-12 text-center py-5" id="loadingDiv">
            <i class="fas fa-spinner fa-spin fa-3x text-primary mb-3"></i>
            <h5 class="text-muted">Anketler Yükleniyor...</h5>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function parseJwt(token) {
            try { return JSON.parse(decodeURIComponent(window.atob(token.split('.')[1].replace(/-/g, '+').replace(/_/g, '/')).split('').map(function(c) { return '%' + ('00' + c.charCodeAt(0).toString(16)).slice(-2); }).join(''))); } catch (e) { return null; }
        }

        $(document).ready(function () {
            var token = localStorage.getItem("token");
            if (!token) { window.location.href = "/Auth/Login"; return; }

            var decodedToken = parseJwt(token);
            if (decodedToken) {
                var userName = decodedToken.unique_name || decodedToken["http://schemas.xmlsoap.org/ws/2005/05/identity/claims/name"] || "Kullanıcı";
                $("#lblWelcomeName").text(userName.toUpperCase());
            }

            $.ajax({
                url: "https://localhost:7094/api/Survey",
                type: "GET",
                headers: { "Authorization": "Bearer " + token },
                success: function (res) {
                    $("#loadingDiv").remove();
                    var container = $("#publicSurveysContainer");

                    if (!res || res.length === 0) {
                        container.html('<div class="col-12 text-center py-5"><i class="fa-solid fa-box-open fa-4x text-muted mb-3 d-block"></i><h5 class="text-muted">Sistemde henüz bir anket bulunmuyor.</h5></div>');
                        return;
                    }

                    // User Side: Sadece aktif anketleri göster
                    var publicSurveys = res.filter(s => s.isActive === true);

                    if (publicSurveys.length === 0) {
                        container.html('<div class="col-12 text-center py-5"><i class="fa-solid fa-lock fa-4x text-muted mb-3 d-block opacity-50"></i><h5 class="text-muted mt-3">Şu an sizin için erişilebilir aktif bir anket bulunmuyor.</h5></div>');
                        return;
                    }

                    publicSurveys.forEach(function (s) {
                        var desc = s.description ? s.description : "Açıklama girilmemiş.";
                        var date = new Date(s.createdDate).toLocaleDateString("tr-TR");
                        var endDateStr = s.endDate ? new Date(s.endDate).toLocaleDateString("tr-TR") : "Süresiz";

                        var cardHtml = `
                            <div class="col-xl-3 col-lg-4 col-md-6 mb-4">
                                <div class="card h-100 shadow-sm border-0 rounded-4 hover-lift overflow-hidden">
                                    <div class="card-header bg-primary text-white text-center py-4 border-0">
                                        <i class="fa-solid fa-clipboard-list fa-3x mb-2 opacity-75"></i>
                                        <h5 class="m-0 fw-bold text-truncate px-2" title="${s.title}">${s.title}</h5>
                                    </div>
                                    <div class="card-body d-flex flex-column p-4">
                                        <p class="text-muted small mb-4 flex-grow-1">${desc}</p>
                                        <div class="d-flex justify-content-between align-items-center mb-1 small">
                                            <span class="text-muted"><i class="fa-regular fa-calendar me-1"></i> Başlangıç</span>
                                            <span class="fw-bold text-dark">${date}</span>
                                        </div>
                                        <div class="d-flex justify-content-between align-items-center small">
                                            <span class="text-muted"><i class="fa-regular fa-clock me-1"></i> Bitiş</span>
                                            <span class="fw-bold text-danger">${endDateStr}</span>
                                        </div>
                                    </div>
                                    <div class="card-footer bg-white border-0 text-center pb-4 pt-0">
                                        <a href="/Survey/Solve/${s.id}" class="btn btn-outline-primary w-100 fw-bold rounded-pill py-2">
                                            Ankete Katıl <i class="fa-solid fa-arrow-right ms-1"></i>
                                        </a>
                                    </div>
                                </div>
                            </div>
                        `;
                        container.append(cardHtml);
                    });
                },
                error: function (xhr) { if(xhr.status === 401) window.location.href = "/Auth/Login"; }
            });
        });
    </script>
    <style>
        .hover-lift {
            transition: transform 0.2s ease, box-shadow 0.2s ease;
        }

            .hover-lift:hover {
                transform: translateY(-5px);
                box-shadow: 0 10px 25px rgba(0,0,0,0.15) !important;
            }

        body.dark-mode .hover-lift:hover {
            box-shadow: 0 10px 25px rgba(0,0,0,0.5) !important;
        }

        body.dark-mode .text-dark {
            color: #fff !important;
        }
    </style>
}