@{
    ViewData["Title"] = "Yönetim Paneli";
}

<div class="container-fluid mt-4">
    <!-- Sayfa Başlığı -->
    <div class="d-sm-flex align-items-center justify-content-between mb-4">
        <h1 class="h3 mb-0 text-gray-800 fw-bold"><i class="fa-solid fa-chart-pie text-primary me-2"></i> Sistem Özeti</h1>
        <a href="/Survey/Index" class="d-none d-sm-inline-block btn btn-sm btn-primary shadow-sm">
            <i class="fas fa-plus fa-sm text-white-50"></i> Anketlere Git
        </a>
    </div>

    <!-- İstatistik Kartları -->
    <div class="row">
        <!-- Toplam Anket -->
        <div class="col-xl-3 col-md-6 mb-4">
            <div class="card shadow h-100 py-2 border-0" style="border-left: 5px solid #4e73df !important;">
                <div class="card-body">
                    <div class="row no-gutters align-items-center">
                        <div class="col mr-2">
                            <div class="text-xs fw-bold text-primary text-uppercase mb-1" style="letter-spacing: 0.05em;">
                                Toplam Anket
                            </div>
                            <div class="h3 mb-0 fw-bold text-gray-800" id="statTotalSurveys">0</div>
                        </div>
                        <div class="col-auto">
                            <i class="fas fa-clipboard-list fa-2x text-gray-300" style="opacity: 0.5;"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Aktif Anketler -->
        <div class="col-xl-3 col-md-6 mb-4">
            <div class="card shadow h-100 py-2 border-0" style="border-left: 5px solid #1cc88a !important;">
                <div class="card-body">
                    <div class="row no-gutters align-items-center">
                        <div class="col mr-2">
                            <div class="text-xs fw-bold text-success text-uppercase mb-1" style="letter-spacing: 0.05em;">
                                Yayındaki (Aktif)
                            </div>
                            <div class="h3 mb-0 fw-bold text-gray-800" id="statActiveSurveys">0</div>
                        </div>
                        <div class="col-auto">
                            <i class="fas fa-check-circle fa-2x text-gray-300" style="opacity: 0.5;"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Toplam Soru -->
        <div class="col-xl-3 col-md-6 mb-4">
            <div class="card shadow h-100 py-2 border-0" style="border-left: 5px solid #f6c23e !important;">
                <div class="card-body">
                    <div class="row no-gutters align-items-center">
                        <div class="col mr-2">
                            <div class="text-xs fw-bold text-warning text-uppercase mb-1" style="letter-spacing: 0.05em;">
                                Toplam Soru Sayısı
                            </div>
                            <div class="h3 mb-0 fw-bold text-gray-800" id="statTotalQuestions">0</div>
                        </div>
                        <div class="col-auto">
                            <i class="fas fa-comments fa-2x text-gray-300" style="opacity: 0.5;"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Toplam Yanıt -->
        <div class="col-xl-3 col-md-6 mb-4">
            <div class="card shadow h-100 py-2 border-0" style="border-left: 5px solid #36b9cc !important;">
                <div class="card-body">
                    <div class="row no-gutters align-items-center">
                        <div class="col mr-2">
                            <div class="text-xs fw-bold text-info text-uppercase mb-1" style="letter-spacing: 0.05em;">
                                Toplanan Yanıtlar
                            </div>
                            <div class="h3 mb-0 fw-bold text-gray-800" id="statTotalAnswers">0</div>
                        </div>
                        <div class="col-auto">
                            <i class="fas fa-users fa-2x text-gray-300" style="opacity: 0.5;"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Alt Bölüm: Son Anketler Tablosu -->
    <div class="row">
        <div class="col-lg-12">
            <div class="card shadow mb-4 border-0">
                <div class="card-header py-3 bg-white d-flex flex-row align-items-center justify-content-between">
                    <h6 class="m-0 fw-bold text-primary"><i class="fa fa-clock text-muted me-2"></i> Sistemdeki Son Anketler</h6>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="table-light text-muted">
                                <tr>
                                    <th class="ps-4">Anket Adı</th>
                                    <th>Oluşturulma</th>
                                    <th>Bitiş Tarihi</th>
                                    <th>Durum</th>
                                    <th class="text-end pe-4">Kısayol</th>
                                </tr>
                            </thead>
                            <tbody id="recentSurveysTable">
                                <tr><td colspan="5" class="text-center text-muted py-4"><i class="fa fa-spinner fa-spin me-2"></i> Veriler yükleniyor...</td></tr>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            // Animasyon Fonksiyonu: Sayıları 0'dan hedefe doğru saydırır
            function animateValue(id, start, end, duration) {
                var obj = document.getElementById(id);
                if (!obj) return;

                if (start === end || end === 0) {
                    obj.innerHTML = end;
                    return;
                }

                var range = end - start;
                var current = start;
                var increment = end > start ? 1 : -1;
                var stepTime = Math.abs(Math.floor(duration / range));
                if(stepTime < 5) stepTime = 5;

                var timer = setInterval(function() {
                    current += increment;
                    obj.innerHTML = current;
                    if (current == end) {
                        clearInterval(timer);
                    }
                }, stepTime);
            }

            function loadDashboardData() {
                var token = localStorage.getItem("token");
                if (!token) return;

                // 1. İSTATİSTİKLERİ YENİ YAZDIĞIMIZ API'DEN GERÇEK ZAMANLI ÇEK
                $.ajax({
                    url: "https://localhost:7094/api/Survey/GetDashboardStats",
                    type: "GET",
                    headers: { "Authorization": "Bearer " + token },
                    success: function (res) {
                        if (res.status && res.data) {
                            var stats = res.data;

                            // Backend'den gelen gerçek verileri animasyonla yazdırıyoruz!
                            animateValue("statTotalSurveys", 0, stats.totalSurveys, 1000);
                            animateValue("statActiveSurveys", 0, stats.activeSurveys, 1000);
                            animateValue("statTotalQuestions", 0, stats.totalQuestions, 1200);
                            animateValue("statTotalAnswers", 0, stats.totalAnswers, 1500);
                        }
                    },
                    error: function () {
                        console.error("İstatistikler çekilemedi.");
                    }
                });

                // 2. ALT TABLO İÇİN ANKETLERİ ÇEK VE DOLDUR
                $.ajax({
                    url: "https://localhost:7094/api/Survey",
                    type: "GET",
                    headers: { "Authorization": "Bearer " + token },
                    success: function (res) {
                        var surveys = res || [];
                        var html = "";

                        // En yeni eklenen 5 anketi filtrele
                        var recentSurveys = surveys.sort((a,b) => b.id - a.id).slice(0, 5);

                        if (recentSurveys.length > 0) {
                            recentSurveys.forEach(function (s) {
                                var date = new Date(s.createdDate).toLocaleDateString("tr-TR");
                                var endDate = s.endDate ? new Date(s.endDate).toLocaleDateString("tr-TR") : '<span class="text-muted">Süresiz</span>';

                                var statusBadge = s.isActive
                                    ? '<span class="badge bg-success bg-opacity-75 text-white px-3 py-2 rounded-pill"><i class="fa fa-play me-1"></i> Aktif</span>'
                                    : '<span class="badge bg-danger bg-opacity-75 text-white px-3 py-2 rounded-pill"><i class="fa fa-pause me-1"></i> Pasif</span>';

                                html += `
                                    <tr>
                                        <td class="ps-4 fw-bold text-dark">${s.title}</td>
                                        <td>${date}</td>
                                        <td>${endDate}</td>
                                        <td>${statusBadge}</td>
                                        <td class="text-end pe-4">
                                            <a href="/Survey/Detail/${s.id}" class="btn btn-sm btn-light border shadow-sm text-primary">
                                                <i class="fa fa-pen"></i> Yönet
                                            </a>
                                        </td>
                                    </tr>`;
                            });
                        } else {
                            html = '<tr><td colspan="5" class="text-center text-muted py-5"><i class="fa fa-box-open fa-2x mb-3 d-block opacity-50"></i> Sistemde henüz anket bulunmuyor.</td></tr>';
                        }

                        $("#recentSurveysTable").html(html);
                    }
                });
            }

            // Sayfa yüklendiğinde dataları çek
            loadDashboardData();
        });
    </script>
}