@{
    ViewData["Title"] = "Profilim";
}

<div class="container-fluid mt-4">
    <div class="row justify-content-center">
        <div class="col-lg-6 col-md-8">
            <div class="card shadow border-0 rounded-4 mt-5">
                <div class="card-body p-5 text-center relative">

                    <!-- Profil Fotoğrafı (Dinamik) -->
                    <img id="profileAvatar" src="https://ui-avatars.com/api/?name=U&background=4e73df&color=fff&size=128"
                         class="rounded-circle shadow border border-4 border-white mb-4"
                         style="width: 120px; height: 120px; margin-top: -80px; background: white;">

                    <h3 class="fw-bold text-dark mb-1" id="profileName">Yükleniyor...</h3>
                    <p class="text-muted mb-4" id="profileEmail"><i class="fa-solid fa-envelope me-1"></i> Yükleniyor...</p>

                    <div id="profileRoleBadge" class="mb-4">
                        <!-- Yetki rozeti buraya gelecek -->
                    </div>

                    <hr class="mb-4">

                    <div class="row text-start">
                        <div class="col-sm-6 mb-3">
                            <label class="text-muted small fw-bold text-uppercase">Ad Soyad</label>
                            <p class="text-dark fw-semibold mb-0" id="detailName">-</p>
                        </div>
                        <div class="col-sm-6 mb-3">
                            <label class="text-muted small fw-bold text-uppercase">E-Posta Adresi</label>
                            <p class="text-dark fw-semibold mb-0" id="detailEmail">-</p>
                        </div>
                    </div>

                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // JWT'yi okuma fonksiyonu
        function parseJwt(token) {
            try {
                var base64Url = token.split('.')[1];
                var base64 = base64Url.replace(/-/g, '+').replace(/_/g, '/');
                var jsonPayload = decodeURIComponent(window.atob(base64).split('').map(function(c) {
                    return '%' + ('00' + c.charCodeAt(0).toString(16)).slice(-2);
                }).join(''));
                return JSON.parse(jsonPayload);
            } catch (e) {
                return null;
            }
        }

        $(document).ready(function () {
            var token = localStorage.getItem("token");
            if(token) {
                var decoded = parseJwt(token);
                if(decoded) {
                    // Token içindeki verileri yakala
                    var fullName = decoded.FullName || decoded["FullName"] || "Kullanıcı";
                    var email = decoded["http://schemas.xmlsoap.org/ws/2005/05/identity/claims/emailaddress"] || decoded.email || "E-Posta Bulunamadı";
                    var role = decoded["http://schemas.microsoft.com/ws/2008/06/identity/claims/role"] || decoded.role || "User";

                    // Ekrana bas
                    $("#profileName").text(fullName);
                    $("#detailName").text(fullName);
                    $("#profileEmail").html('<i class="fa-solid fa-envelope me-1"></i> ' + email);
                    $("#detailEmail").text(email);

                    // Baş harfe göre Avatar
                    var firstLetter = fullName.charAt(0).toUpperCase();
                    $("#profileAvatar").attr("src", "https://ui-avatars.com/api/?name=" + firstLetter + "&background=4e73df&color=fff&bold=true&size=128");

                    // Rol Rozeti (Badge)
                    if(role === "SuperAdmin") {
                        $("#profileRoleBadge").html('<span class="badge bg-dark px-4 py-2 fs-6 rounded-pill"><i class="fa fa-crown text-warning me-1"></i> SuperAdmin</span>');
                    } else if(role === "Admin") {
                        $("#profileRoleBadge").html('<span class="badge bg-danger px-4 py-2 fs-6 rounded-pill"><i class="fa fa-shield-halved me-1"></i> Admin</span>');
                    } else {
                        $("#profileRoleBadge").html('<span class="badge bg-secondary px-4 py-2 fs-6 rounded-pill"><i class="fa fa-user me-1"></i> Standart Kullanıcı</span>');
                    }
                }
            }
        });
    </script>
}