@{
    ViewData["Title"] = "Anketi Çöz";
    Layout = "~/Views/Shared/_UserLayout.cshtml";
}

<div class="container mt-4 mb-5">
    <div class="row justify-content-center">
        <div class="col-lg-8 col-md-10">

            <div id="loadingDiv" class="text-center py-5">
                <i class="fas fa-spinner fa-spin fa-3x text-primary mb-3"></i>
                <h5 class="text-muted">Anket Yükleniyor...</h5>
            </div>

            <div id="surveyCard" class="card shadow border-0 rounded-4 overflow-hidden" style="display:none;">

                <div class="card-header bg-primary text-white p-4 p-md-5 border-0 position-relative">
                    <h2 class="fw-bold mb-3" id="lblSurveyTitle">Yükleniyor...</h2>
                    <p class="fs-6 mb-0 opacity-75" id="lblSurveyDesc">Açıklama yükleniyor...</p>
                    <i class="fa-solid fa-clipboard-question position-absolute text-white opacity-25" style="font-size: 8rem; right: -20px; bottom: -20px;"></i>
                </div>

                <div class="card-body p-4 p-md-5 bg-light">
                    <form id="frmSolveSurvey">
                        <div id="questionsContainer"></div>

                        <hr class="my-5 opacity-25">

                        <div class="text-end">
                            <button type="button" id="btnSubmitAnswers" class="btn btn-primary btn-lg rounded-pill px-5 fw-bold shadow">
                                <i class="fa-solid fa-paper-plane me-2"></i> Cevapları Gönder
                            </button>
                        </div>
                    </form>
                </div>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            var surveyId = '@(ViewBag.SurveyId ?? 0)';
            var token = localStorage.getItem("token");

            if (!token) {
                window.location.replace("/Auth/Login");
                return;
            }

            if (surveyId == '0' || surveyId == '') {
                Swal.fire('Hata', 'Geçersiz anket numarası.', 'error').then(() => {
                    window.location.replace("/Home/Surveys");
                });
                return;
            }

            // 1. API'DEN ANKETİ ÇEK
            $.ajax({
                url: "https://localhost:7094/api/Survey/" + surveyId,
                type: "GET",
                headers: { "Authorization": "Bearer " + token },
                success: function (res) {
                    $("#loadingDiv").hide();

                    var survey = null;
                    if (res && res.data && res.data.title) {
                        survey = res.data;
                    } else if (res && res.title) {
                        survey = res;
                    }

                    if (!survey) {
                        Swal.fire('Hata', 'Anket verisi sunucudan okunamadı.', 'error');
                        return;
                    }

                    if (survey.isActive === false) {
                        Swal.fire('Erişim Reddedildi', 'Bu anket katılıma kapatılmıştır.', 'warning').then(() => {
                            window.location.replace("/Home/Surveys");
                        });
                        return;
                    }

                    $("#lblSurveyTitle").text(survey.title || survey.Title);
                    $("#lblSurveyDesc").text(survey.description || survey.Description || "Bu anket için açıklama girilmemiştir.");

                    renderQuestions(survey.questions || survey.Questions);

                    $("#surveyCard").fadeIn();
                },
                error: function (xhr) {
                    Swal.fire('Hata!', 'Anket bilgileri alınırken hata oluştu.', 'error');
                }
            });

            // 2. SORULARI ÇİZ (TÜM NUMARA HATALARI DÜZELTİLDİ!)
            function renderQuestions(questions) {
                var container = $("#questionsContainer");
                container.empty();

                if (!questions || questions.length === 0) {
                    container.html('<div class="alert alert-warning text-center">Bu ankete henüz soru eklenmemiş.</div>');
                    $("#btnSubmitAnswers").hide();
                    return;
                }

                questions.forEach(function (q, index) {
                    var questionText = q.text || q.Text || q.questionText || q.QuestionText;
                    var qId = q.id || q.Id;
                    var qType = q.type || q.Type;

                    var questionHtml = `
                        <div class="question-block bg-white p-4 rounded-4 shadow-sm mb-4 border border-1" data-question-id="${qId}" data-question-type="${qType}">
                            <h5 class="fw-bold text-dark mb-4">
                                <span class="badge bg-primary me-2 rounded-circle">${index + 1}</span> ${questionText}
                            </h5>
                            <div class="options-container ps-2 ps-md-4">
                    `;

                    // qType === 1 : AÇIK UÇLU (METİN)
                    if (qType === 1 || qType === "Text") {
                        questionHtml += `
                            <textarea class="form-control text-answer-input" name="q_${qId}" rows="3" placeholder="Lütfen cevabınızı buraya yazınız..."></textarea>
                        `;
                    }
                    // qType === 2 (Radio) veya 3 (Checkbox) : ŞIKLI SORULAR
                    else {
                        var optionsList = q.options || q.Options;

                        if (!optionsList || optionsList.length === 0) {
                            questionHtml += `<span class="text-danger small"><i class="fa-solid fa-triangle-exclamation"></i> Bu soru için seçenek bulunamadı. Lütfen admin panelinden şık ekleyin.</span>`;
                        } else {
                            optionsList.forEach(function (opt) {
                                var optId = opt.id || opt.Id;
                                var optText = opt.optionText || opt.OptionText || opt.text || opt.Text || "Seçenek";

                                // qType === 3 : CHECKBOX (ÇOKLU SEÇİM)
                                if (qType === 3 || qType === "Checkbox" || qType === "MultipleChoice") {
                                    questionHtml += `
                                        <div class="form-check custom-checkbox mb-3">
                                            <input class="form-check-input option-input" type="checkbox" name="q_${qId}" id="opt_${optId}" value="${optId}">
                                            <label class="form-check-label w-100 p-2 rounded" for="opt_${optId}" style="cursor:pointer;">
                                                ${optText}
                                            </label>
                                        </div>
                                    `;
                                }
                                // qType === 2 : RADIO (TEK SEÇİM)
                                else {
                                    questionHtml += `
                                        <div class="form-check custom-radio mb-3">
                                            <input class="form-check-input option-input" type="radio" name="q_${qId}" id="opt_${optId}" value="${optId}">
                                            <label class="form-check-label w-100 p-2 rounded" for="opt_${optId}" style="cursor:pointer;">
                                                ${optText}
                                            </label>
                                        </div>
                                    `;
                                }
                            });
                        }
                    }

                    questionHtml += `</div></div>`;
                    container.append(questionHtml);
                });

                $(".option-input").change(function() {
                    var qName = $(this).attr("name");
                    if ($(this).attr('type') === 'radio') {
                        $(`input[name='${qName}']`).siblings('label').removeClass('bg-primary bg-opacity-10 text-primary fw-bold');
                    }
                    if ($(this).is(':checked')) {
                        $(this).siblings('label').addClass('bg-primary bg-opacity-10 text-primary fw-bold');
                    } else {
                        $(this).siblings('label').removeClass('bg-primary bg-opacity-10 text-primary fw-bold');
                    }
                });
            }

            // 3. GÖNDERME KISMI
            $("#btnSubmitAnswers").click(function () {
                var btn = $(this);
                var answers = [];
                var unAnsweredCount = 0;

                $(".question-block").each(function () {
                    var qId = $(this).data("question-id");
                    var qType = $(this).data("question-type");

                    // qType === 1 : AÇIK UÇLU METİN
                    if (qType === 1 || qType === "Text") {
                        var textInput = $(this).find("textarea.text-answer-input");
                        var textVal = textInput.length > 0 ? textInput.val().trim() : "";

                        if (textVal === "") {
                            unAnsweredCount++;
                            $(this).addClass("border-danger").removeClass("border-1");
                        } else {
                            $(this).removeClass("border-danger").addClass("border-1");
                            answers.push({
                                QuestionId: qId,
                                SelectedOptionId: null,
                                TextAnswer: textVal
                            });
                        }
                    }
                    // ŞIKLI SORULAR (Radio veya Checkbox)
                    else {
                        var selectedOptions = $(this).find("input.option-input:checked");

                        if (selectedOptions.length === 0) {
                            unAnsweredCount++;
                            $(this).addClass("border-danger").removeClass("border-1");
                        } else {
                            $(this).removeClass("border-danger").addClass("border-1");

                            selectedOptions.each(function () {
                                var valId = parseInt($(this).val());
                                answers.push({
                                    QuestionId: qId,
                                    SelectedOptionId: valId,
                                    TextAnswer: null
                                });
                            });
                        }
                    }
                });

                if (unAnsweredCount > 0) {
                    Swal.fire('Eksik Cevap', `Lütfen tüm soruları cevaplayın. Kırmızı ile işaretlenmiş ${unAnsweredCount} soru boş bırakıldı.`, 'warning');
                    return;
                }

                var payload = {
                    SurveyId: parseInt(surveyId),
                    Answers: answers
                };

                btn.prop("disabled", true).html('<i class="fas fa-spinner fa-spin me-2"></i> Gönderiliyor...');

                $.ajax({
                    url: "https://localhost:7094/api/Answer/Submit",
                    type: "POST",
                    contentType: "application/json",
                    headers: { "Authorization": "Bearer " + token },
                    data: JSON.stringify(payload),
                    success: function (res) {
                        if (res && (res.status === true || res.Status === true)) {
                            Swal.fire({
                                icon: 'success',
                                title: 'Teşekkürler!',
                                text: 'Anket cevaplarınız başarıyla kaydedildi.',
                                confirmButtonText: 'Anasayfaya Dön'
                            }).then(() => {
                                window.location.replace("/Home/Index");
                            });
                        } else {
                            Swal.fire('Hata', res.message || res.Message || 'Cevaplar kaydedilemedi.', 'error');
                            btn.prop("disabled", false).html('<i class="fa-solid fa-paper-plane me-2"></i> Cevapları Gönder');
                        }
                    },
                    error: function (xhr) {
                        var errMsg = 'Sunucuyla iletişim kurulamadı.';
                        if(xhr.responseJSON && xhr.responseJSON.message) errMsg = xhr.responseJSON.message;
                        Swal.fire('Hata!', errMsg, 'error');
                        btn.prop("disabled", false).html('<i class="fa-solid fa-paper-plane me-2"></i> Cevapları Gönder');
                    }
                });
            });
        });
    </script>

    <style>
        .custom-radio input[type="radio"], .custom-checkbox input[type="checkbox"] {
            width: 1.5em;
            height: 1.5em;
            margin-top: 0.25em;
            cursor: pointer;
        }

        .custom-radio label, .custom-checkbox label {
            transition: all 0.2s ease;
        }

        .border-danger {
            border-width: 2px !important;
        }

        body.dark-mode .bg-white {
            background-color: #1f2937 !important;
            border-color: #333 !important;
        }

        body.dark-mode .bg-light {
            background-color: #121212 !important;
        }
    </style>
}