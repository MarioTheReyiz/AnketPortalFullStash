@{
    ViewData["Title"] = "Anket Raporu";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid mt-4 mb-5">
    <div class="d-sm-flex align-items-center justify-content-between mb-4">
        <h1 class="h3 mb-0 text-gray-800 fw-bold">
            <i class="fa-solid fa-chart-pie text-primary me-2"></i>
            <span id="lblSurveyTitle">Rapor Yükleniyor...</span>
        </h1>
        <div>
            <!-- EXCEL İNDİR BUTONU -->
            <button id="btnExportExcel" class="btn btn-sm btn-success shadow-sm me-2 d-none">
                <i class="fa-solid fa-file-excel me-1"></i> Sonuçları İndir (Excel)
            </button>
            <a href="/Survey/Index" class="btn btn-sm btn-secondary shadow-sm">
                <i class="fa-solid fa-arrow-left fa-sm text-white-50"></i> Anketlere Dön
            </a>
        </div>
    </div>

    <!-- GRAFİKLER VE LİSTELER ALANI -->
    <div class="row" id="chartsContainer">
        <div class="col-12 text-center py-5" id="loadingDiv">
            <i class="fas fa-spinner fa-spin fa-3x text-primary mb-3"></i>
            <h5 class="text-muted">Raporlar Derleniyor...</h5>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

    <script>
        $(document).ready(function () {
            var pathArray = window.location.pathname.split('/');
            var surveyId = pathArray[pathArray.length - 1];
            var token = localStorage.getItem("token");
            var globalSurveyData = null;

            if (!token) {
                window.location.replace("/Auth/Login");
                return;
            }

            // API'DEN VERİYİ ÇEK
            $.ajax({
                url: "https://localhost:7094/api/Survey/" + surveyId + "/Results",
                type: "GET",
                headers: { "Authorization": "Bearer " + token },
                success: function (res) {
                    $("#loadingDiv").remove();

                    globalSurveyData = res.data ? res.data : (res.Data ? res.Data : res);

                    if (!globalSurveyData) {
                        Swal.fire('Hata', 'Rapor verisi bulunamadı.', 'error');
                        return;
                    }

                    var questions = globalSurveyData.questions || globalSurveyData.Questions || [];
                    var surveyTitle = (globalSurveyData.title || globalSurveyData.Title || "Anket") + " Raporu";

                    $("#lblSurveyTitle").text(surveyTitle);

                    if (!questions || questions.length === 0) {
                        $("#chartsContainer").html('<div class="col-12"><div class="alert alert-warning text-center">Bu anket için henüz soru veya yanıt bulunmuyor.</div></div>');
                        return;
                    }

                    $("#btnExportExcel").removeClass("d-none");

                    // SORULARI DÖN VE EKRANA BAS
                    questions.forEach(function (q, index) {
                        var qText = q.questionText || q.QuestionText || q.text || q.Text || "Soru " + (index + 1);
                        var qType = q.type || q.Type;
                        var options = q.options || q.Options || [];
                        var textAnswers = q.textAnswers || q.TextAnswers || [];
                        var totalVotes = q.totalVotes || q.TotalVotes || 0;

                        var questionCard = `
                            <div class="col-xl-6 col-lg-12 mb-4">
                                <div class="card shadow-sm border-0 h-100 rounded-4">
                                    <div class="card-header bg-white border-bottom-0 pt-4 pb-0">
                                        <h5 class="fw-bold text-primary mb-1">Soru ${index + 1}</h5>
                                        <p class="text-dark fs-5 mb-0">${qText}</p>
                                    </div>
                                    <div class="card-body d-flex flex-column" id="cardBody_${index}">
                                    </div>
                                </div>
                            </div>
                        `;
                        $("#chartsContainer").append(questionCard);
                        var cardBody = $(`#cardBody_${index}`);

                        // AÇIK UÇLU SORUYSA
                        if (qType === 1 || qType === "Text") {
                            var htmlList = `<div class="alert alert-primary bg-opacity-10 border-0 text-primary fw-bold py-2 px-3 mb-3"><i class="fa-solid fa-users me-2"></i> Toplam ${totalVotes} kişi metin yanıtı bıraktı.</div>`;

                            if (textAnswers.length === 0) {
                                htmlList += '<div class="text-muted text-center py-4"><i class="fa-solid fa-comment-slash fa-2x mb-2"></i><br>Henüz yanıt yok.</div>';
                            } else {
                                htmlList += '<div class="list-group list-group-flush rounded-3 shadow-sm" style="max-height: 250px; overflow-y: auto;">';
                                textAnswers.forEach(function(txt) {
                                    htmlList += `<div class="list-group-item list-group-item-action border-bottom py-3">
                                                    <i class="fa-solid fa-quote-left text-primary opacity-50 me-2"></i> ${txt}
                                                 </div>`;
                                });
                                htmlList += '</div>';
                            }
                            cardBody.html(htmlList);
                        }
                        // ÇOKTAN SEÇMELİ / CHECKBOX İSE
                        else {
                            cardBody.html(`
                                <div class="alert alert-success bg-opacity-10 border-0 text-success fw-bold py-2 px-3 mb-3"><i class="fa-solid fa-chart-bar me-2"></i> Toplam ${totalVotes} oy kullanıldı.</div>
                                <div class="chart-container flex-grow-1" style="position: relative; min-height: 250px; width:100%">
                                    <canvas id="chart_${index}"></canvas>
                                </div>
                            `);

                            var labels = [];
                            var counts = [];
                            var bgColors = ['#4e73df', '#1cc88a', '#36b9cc', '#f6c23e', '#e74a3b', '#858796', '#5a5c69', '#2e59d9'];

                            options.forEach(function (opt) {
                                labels.push(opt.optionText || opt.OptionText || "Şık");
                                counts.push(opt.count || opt.Count || 0);
                            });

                            var isAllZero = counts.every(item => item === 0);
                            var ctx = document.getElementById(`chart_${index}`).getContext('2d');
                            new Chart(ctx, {
                                type: 'bar',
                                data: {
                                    labels: labels,
                                    datasets: [{
                                        label: 'Oy Sayısı',
                                        data: counts,
                                        backgroundColor: bgColors.slice(0, labels.length),
                                        borderWidth: 0,
                                        borderRadius: 6
                                    }]
                                },
                                options: {
                                    responsive: true,
                                    maintainAspectRatio: false,
                                    plugins: { legend: { display: false } },
                                    scales: { y: { beginAtZero: true, ticks: { precision: 0 } } }
                                }
                            });
                        }
                    });
                },
                error: function () {
                    $("#loadingDiv").remove();
                    Swal.fire('Hata', 'Raporlar çekilemedi.', 'error');
                }
            });

            // ==========================================
            // MÜKEMMELLEŞTİRİLMİŞ EXCEL İNDİRME İŞLEMİ
            // ==========================================
            $("#btnExportExcel").click(function() {
                if (!globalSurveyData) return;
                var questions = globalSurveyData.questions || globalSurveyData.Questions || [];

                // BOM ekleyerek Türkçe karakter sorununu çözer
                var csvContent = "\uFEFF";

                // Metinleri Excel için güvenli hale getiren yardımcı fonksiyon
                function escapeCsv(text) {
                    if (text === null || text === undefined) return '""';
                    // İçindeki Enter karakterlerini boşlukla değiştir, varsa çift tırnakları "" yap
                    var safeText = text.toString().replace(/\r?\n|\r/g, " ").replace(/"/g, '""');
                    return `"${safeText}"`;
                }

                // Başlık
                var sTitle = globalSurveyData.title || globalSurveyData.Title || "Anket";
                csvContent += `Anket Adı:;${escapeCsv(sTitle)}\n\n`;

                // Kolon Başlıkları (Türkiye'deki Excel'ler ; (noktalı virgül) sever)
                csvContent += "Soru No;Soru Tipi;Soru Metni;Şık / Kullanıcı Cevabı;Oy (Kişi Sayısı)\n";

                questions.forEach(function(q, index) {
                    var qNo = index + 1;
                    var qText = q.questionText || q.QuestionText || q.text || q.Text || "";
                    var qType = q.type || q.Type;
                    var options = q.options || q.Options || [];
                    var textAnswers = q.textAnswers || q.TextAnswers || [];

                    // Eğer Açık Uçlu Soru ise
                    if (qType === 1 || qType === "Text") {
                        if (textAnswers.length === 0) {
                            csvContent += `${qNo};Açık Uçlu;${escapeCsv(qText)};"Yanıt Yok";0\n`;
                        } else {
                            textAnswers.forEach(function(txt) {
                                csvContent += `${qNo};Açık Uçlu;${escapeCsv(qText)};${escapeCsv(txt)};1\n`;
                            });
                        }
                    }
                    // Çoktan Seçmeli / Checkbox İse
                    else {
                        var typeName = (qType === 3) ? "Çoklu Seçim" : "Tekli Seçim";
                        if (options.length === 0) {
                            csvContent += `${qNo};${typeName};${escapeCsv(qText)};"Şık Yok";0\n`;
                        } else {
                            options.forEach(function(opt) {
                                var optText = opt.optionText || opt.OptionText || "Bilinmiyor";
                                var count = opt.count || opt.Count || 0;
                                csvContent += `${qNo};${typeName};${escapeCsv(qText)};${escapeCsv(optText)};${count}\n`;
                            });
                        }
                    }

                    // Okunabilirliği artırmak için her sorudan sonra Excel'de bir satır boşluk bırakalım
                    csvContent += ";;;;\n";
                });

                // Dosyayı İndirtme
                var blob = new Blob([csvContent], { type: 'text/csv;charset=utf-8;' });
                var url = URL.createObjectURL(blob);
                var link = document.createElement("a");
                link.setAttribute("href", url);

                // İnen dosya adını güzelleştirelim
                var safeFileName = sTitle.substring(0, 15).replace(/[^a-z0-9]/gi, '_').toLowerCase();
                link.setAttribute("download", `AnketRaporu_${safeFileName}.csv`);

                document.body.appendChild(link);
                link.click();
                document.body.removeChild(link);
            });
        });
    </script>
}