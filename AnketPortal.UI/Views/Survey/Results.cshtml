@{
    ViewData["Title"] = "Anket Sonuçları";
    Layout = "~/Views/Shared/_Layout.cshtml"; // Admin tarafıysa _Layout, User tarafıysa _UserLayout
}

<div class="container-fluid mt-4 mb-5">
    <!-- BAŞLIK -->
    <div class="d-sm-flex align-items-center justify-content-between mb-4">
        <h1 class="h3 mb-0 text-gray-800 fw-bold">
            <i class="fa-solid fa-chart-pie text-primary me-2"></i>
            <span id="lblSurveyTitle">Yükleniyor...</span>
        </h1>
        <div>
            <!-- EXCEL İNDİR BUTONU -->
            <button id="btnExportExcel" class="btn btn-sm btn-success shadow-sm me-2 d-none">
                <i class="fa-solid fa-file-excel me-1"></i> Sonuçları İndir (CSV)
            </button>
            <a href="/Survey/Index" class="btn btn-sm btn-secondary shadow-sm">
                <i class="fa-solid fa-arrow-left fa-sm text-white-50"></i> Anketlere Dön
            </a>
        </div>
    </div>

    <!-- GRAFİKLER ALANI -->
    <div class="row" id="chartsContainer">
        <!-- Yükleniyor animasyonu -->
        <div class="col-12 text-center py-5" id="loadingDiv">
            <i class="fas fa-spinner fa-spin fa-3x text-primary mb-3"></i>
            <h5 class="text-muted">Veriler analiz ediliyor...</h5>
        </div>
    </div>
</div>

@section Scripts {
    <!-- Chart.js Kütüphanesi -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

    <script>
        $(document).ready(function () {
            var pathArray = window.location.pathname.split('/');
            var surveyId = pathArray[pathArray.length - 1];
            var token = localStorage.getItem("token");

            if (!token) {
                window.location.replace("/Auth/Login");
                return;
            }

            $.ajax({
                // API URL'si
                url: "https://localhost:7094/api/Survey/" + surveyId + "/Results", // Kendi portuna göre düzelt!
                type: "GET",
                headers: { "Authorization": "Bearer " + token },
                success: function (res) {

                    // 1. Yükleniyor animasyonunu temizle
                    $("#loadingDiv").remove();

                    var surveyData = res.data ? res.data : res;

                    if (!surveyData) {
                        Swal.fire('Hata', 'Rapor verisi bulunamadı.', 'error');
                        return;
                    }

                    var questions = [];

                    // 2. GELEN VERİ BİR DİZİ Mİ YOKSA NESNE Mİ KONTROL ET (undefined hatasını KÖKÜNDEN çözer!)
                    if (Array.isArray(surveyData)) {
                        // API bir liste (ResultDto listesi) dönmüş
                        $("#lblSurveyTitle").text("Anket Raporu");
                        questions = surveyData;
                    } else {
                        // API bir nesne (Survey objesi) dönmüş
                        var sTitle = surveyData.title || surveyData.Title || surveyData.name || surveyData.Name || "Bilinmeyen Anket";
                        $("#lblSurveyTitle").text(sTitle + " - Raporu");
                        questions = surveyData.questions || surveyData.Questions || [];
                    }

                    // 3. EĞER HİÇ SORU/CEVAP YOKSA
                    if (questions.length === 0) {
                        $("#chartsContainer").html('<div class="col-12"><div class="alert alert-warning text-center">Bu anket için henüz soru veya yanıt bulunmuyor.</div></div>');
                        return;
                    }

                    // Veri varsa indirme tuşunu göster
                    $("#btnExportExcel").removeClass("d-none");

                    // 4. GRAFİKLERİ EKRANA ÇİZ
                    questions.forEach(function (q, index) {
                        // DTO veya Model'deki tüm isim ihtimalleri (Büyük/Küçük harf garantili)
                        var qText = q.questionText || q.QuestionText || q.text || q.Text || "Soru " + (index + 1);
                        var options = q.options || q.Options || q.results || q.Results || [];

                        var questionCard = `
                            <div class="col-xl-6 col-lg-12 mb-4">
                                <div class="card shadow-sm border-0 h-100 rounded-4">
                                    <div class="card-header bg-white border-bottom-0 pt-4 pb-0">
                                        <h5 class="fw-bold text-primary">Soru ${index + 1}: <span class="text-dark">${qText}</span></h5>
                                    </div>
                                    <div class="card-body">
                                        <div class="chart-container" style="position: relative; height:300px; width:100%">
                                            <canvas id="chart_${index}"></canvas>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        `;

                        $("#chartsContainer").append(questionCard);

                        var labels = [];
                        var counts = [];
                        var bgColors = ['#4e73df', '#1cc88a', '#36b9cc', '#f6c23e', '#e74a3b', '#858796', '#5a5c69', '#2e59d9'];

                        options.forEach(function (opt) {
                            labels.push(opt.optionText || opt.OptionText || opt.text || opt.Text || "Bilinmeyen Şık");
                            // Count, VoteCount vs.. hepsini dener
                            counts.push(opt.count || opt.Count || opt.voteCount || opt.VoteCount || opt.answerCount || opt.AnswerCount || 0);
                        });

                        var isAllZero = counts.every(item => item === 0);

                        var ctx = document.getElementById(`chart_${index}`).getContext('2d');
                        new Chart(ctx, {
                            type: 'bar',
                            data: {
                                labels: labels,
                                datasets: [{
                                    label: 'Oy Sayısı',
                                    data: counts,
                                    backgroundColor: bgColors.slice(0, labels.length),
                                    borderWidth: 0,
                                    borderRadius: 4
                                }]
                            },
                            options: {
                                responsive: true,
                                maintainAspectRatio: false,
                                plugins: {
                                    legend: { display: false },
                                    title: {
                                        display: isAllZero,
                                        text: 'Bu soruya henüz hiç yanıt verilmemiş.',
                                        color: '#e74a3b',
                                        font: { size: 14 }
                                    }
                                },
                                scales: {
                                    y: {
                                        beginAtZero: true,
                                        ticks: { precision: 0 }
                                    }
                                }
                            }
                        });
                    });
                },
                error: function (xhr) {
                    $("#loadingDiv").remove();
                    Swal.fire('Hata', 'Raporlar API den çekilemedi. Bağlantıyı kontrol edin.', 'error');
                }
            });

            // Excel indirme tuşunun click fonksiyonu
            $("#btnExportExcel").click(function() {
                Swal.fire('Bilgi', 'Excel aktarımı API tarafında hazırlanacak.', 'info');
            });
        });
    </script>
}