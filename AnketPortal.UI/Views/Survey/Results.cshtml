@{
    ViewData["Title"] = "Anket Raporu";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid mt-4 mb-5">
    <div class="d-sm-flex align-items-center justify-content-between mb-4">
        <h1 class="h3 mb-0 text-gray-800 fw-bold">
            <i class="fa-solid fa-chart-pie text-primary me-2"></i>
            <span id="lblSurveyTitle">Rapor Yükleniyor...</span>
        </h1>
        <div>
            <button id="btnExportExcel" class="btn btn-sm btn-success shadow-sm me-2 d-none">
                <i class="fa-solid fa-file-excel me-1"></i> Sonuçları İndir (Excel)
            </button>
            <a href="/Survey/Index" class="btn btn-sm btn-secondary shadow-sm">
                <i class="fa-solid fa-arrow-left me-1"></i> Geri
            </a>
        </div>
    </div>

    <!-- SEKMELER -->
    <ul class="nav nav-pills mb-4 shadow-sm p-2 bg-white rounded-pill" id="reportTabs" role="tablist">
        <li class="nav-item" role="presentation">
            <button class="nav-link active rounded-pill px-4 fw-bold" id="stats-tab" data-bs-toggle="pill" data-bs-target="#stats-content" type="button" role="tab">Genel İstatistikler</button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link rounded-pill px-4 fw-bold" id="participants-tab" data-bs-toggle="pill" data-bs-target="#participants-content" type="button" role="tab">Katılımcı Detayları</button>
        </li>
    </ul>

    <div class="tab-content" id="reportTabsContent">
        <!-- 1. SEKME: İSTATİSTİKLER -->
        <div class="tab-pane fade show active" id="stats-content" role="tabpanel">
            <div class="row" id="chartsContainer">
                <div class="col-12 text-center py-5">
                    <i class="fas fa-spinner fa-spin fa-3x text-primary mb-3"></i>
                    <h5 class="text-muted">Analiz ediliyor...</h5>
                </div>
            </div>
        </div>

        <!-- 2. SEKME: KATILIMCILAR -->
        <div class="tab-pane fade" id="participants-content" role="tabpanel">
            <div class="card shadow border-0 rounded-4">
                <div class="card-body p-4">
                    <div class="row">
                        <div class="col-md-4 border-end">
                            <h6 class="fw-bold text-primary mb-3 border-bottom pb-2">Katılımcı Listesi</h6>
                            <div class="list-group list-group-flush" id="userListGroup" style="max-height: 500px; overflow-y:auto;">
                                <!-- Kullanıcılar buraya gelecek -->
                            </div>
                        </div>
                        <div class="col-md-8">
                            <h6 class="fw-bold text-primary mb-3 border-bottom pb-2">Cevap Kağıdı</h6>
                            <div id="userDetailsArea">
                                <div class="text-center text-muted py-5">Soldan bir kullanıcı seçerek cevaplarını inceleyin.</div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        $(document).ready(function () {
            var surveyId = window.location.pathname.split('/').pop();
            var token = localStorage.getItem("token");
            var globalSurveyData = null;

            // 1. İSTATİSTİKLERİ YÜKLE
            function loadStats() {
                $.ajax({
                    url: `https://localhost:7094/api/Survey/${surveyId}/Results`,
                    type: "GET",
                    headers: { "Authorization": "Bearer " + token },
                    success: function (res) {
                        $("#chartsContainer").empty();
                        globalSurveyData = res.data;
                        $("#lblSurveyTitle").text(globalSurveyData.title + " Raporu");
                        $("#btnExportExcel").removeClass("d-none");

                        globalSurveyData.questions.forEach((q, i) => {
                            if (q.type !== 1) { // Şıklı soruları çiz
                                var card = `<div class="col-xl-6 mb-4"><div class="card shadow-sm border-0 rounded-4"><div class="card-header bg-white border-0 pt-4"><h6 class="fw-bold text-primary">Soru ${i+1}: ${q.questionText}</h6></div><div class="card-body" style="height:300px;"><canvas id="chart_${i}"></canvas></div></div></div>`;
                                $("#chartsContainer").append(card);

                                new Chart(document.getElementById(`chart_${i}`).getContext('2d'), {
                                    type: 'bar',
                                    data: {
                                        labels: q.options.map(o => o.optionText),
                                        datasets: [{ label: 'Oy', data: q.options.map(o => o.count), backgroundColor: '#4e73df', borderRadius: 5 }]
                                    },
                                    options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { display: false } } }
                                });
                            }
                        });
                    }
                });
            }

            // 2. KATILIMCILARI YÜKLE
            $("#participants-tab").one('click', function() {
                $.ajax({
                    url: `https://localhost:7094/api/Survey/${surveyId}/Participants`,
                    type: "GET",
                    headers: { "Authorization": "Bearer " + token },
                    success: function(res) {
                        var list = $("#userListGroup");
                        list.empty();
                        res.data.forEach(u => {
                            list.append(`<button type="button" class="list-group-item list-group-item-action user-item py-3 border-bottom" data-id="${u.id}"><div class="fw-bold">${u.fullName || u.userName}</div><small class="text-muted">${u.email}</small></button>`);
                        });

                        $(".user-item").click(function() {
                            $(".user-item").removeClass("active bg-primary text-white");
                            $(this).addClass("active bg-primary text-white");
                            loadUserAnswers($(this).data("id"));
                        });
                    }
                });
            });

            // 3. KULLANICI CEVAPLARINI YÜKLE
            function loadUserAnswers(userId) {
                $("#userDetailsArea").html('<div class="text-center py-5"><i class="fas fa-spinner fa-spin fa-2x"></i></div>');
                $.ajax({
                    url: `https://localhost:7094/api/Survey/${surveyId}/ParticipantDetails/${userId}`,
                    type: "GET",
                    headers: { "Authorization": "Bearer " + token },
                    success: function(res) {
                        var html = '<div class="accordion" id="answersAccordion">';
                        res.data.forEach((ans, i) => {
                            var cevap = ans.selectedOption || ans.answerText || '<span class="text-danger">Boş Bırakılmış</span>';
                            html += `<div class="accordion-item mb-2 border rounded shadow-sm"><h2 class="accordion-header"><button class="accordion-button collapsed fw-bold small" type="button" data-bs-toggle="collapse" data-bs-target="#ans_${i}">${ans.questionText}</button></h2><div id="ans_${i}" class="accordion-collapse collapse"><div class="accordion-body bg-light"><strong>Cevap:</strong> ${cevap}</div></div></div>`;
                        });
                        html += '</div>';
                        $("#userDetailsArea").html(html);
                    }
                });
            }

            loadStats(); // İlk açılışta istatistikleri yükle
        });
    </script>
}