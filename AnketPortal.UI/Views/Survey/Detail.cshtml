@{
    ViewData["Title"] = "Anket Soruları";
    var surveyId = ViewContext.RouteData.Values["id"];
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="h4 text-gray-800 fw-bold"><i class="fa-solid fa-list-check text-primary me-2"></i> Soru Yönetimi</h2>
        <div>
            <a href="/Survey/Index" class="btn btn-outline-secondary btn-sm me-2 shadow-sm"><i class="fa fa-arrow-left"></i> Geri Dön</a>
            <button class="btn btn-primary btn-sm shadow" id="btnOpenAddModal">
                <i class="fa fa-plus"></i> Yeni Soru Ekle
            </button>
        </div>
    </div>

    <div class="card shadow border-0 rounded-4">
        <div class="card-body p-0" id="questionsList">
            <div class="text-center p-5">
                <i class="fas fa-spinner fa-spin fa-2x text-primary mb-2"></i><br>
                Sorular Yükleniyor...
            </div>
        </div>
    </div>
</div>

<!-- SORU EKLEME/DÜZENLEME MODALI -->
<div class="modal fade" id="questionModal" tabindex="-1" data-bs-backdrop="static">
    <div class="modal-dialog modal-lg">
        <div class="modal-content rounded-4 border-0">
            <div class="modal-header bg-primary text-white border-0">
                <h5 class="modal-title fw-bold" id="modalTitle">Yeni Soru Ekle</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-4">
                <form id="frmQuestion" onsubmit="return false;">
                    <input type="hidden" id="hdnSurveyId" value="@surveyId" />
                    <input type="hidden" id="hdnQuestionId" value="0" />

                    <div class="mb-3">
                        <label class="form-label fw-bold">Soru Metni</label>
                        <input type="text" class="form-control form-control-lg fs-6" id="txtQuestionText" placeholder="Örn: Hizmetimizden memnun kaldınız mı?" required>
                    </div>

                    <div class="mb-3">
                        <label class="form-label small text-muted fw-bold">Medya URL (Resim veya YouTube - Opsiyonel)</label>
                        <input type="text" class="form-control form-control-sm" id="txtMediaUrl" placeholder="https://...">
                    </div>

                    <div class="row mb-4">
                        <div class="col-md-6">
                            <label class="form-label fw-bold">Soru Tipi</label>
                            <select class="form-select" id="cbQuestionType">
                                <option value="1">Kısa Metin (Açık Uçlu)</option>
                                <option value="2">Tek Seçim (Radio Button)</option>
                                <option value="3">Çoklu Seçim (Checkbox)</option>
                            </select>
                        </div>
                        <div class="col-md-6 d-flex align-items-end pb-1">
                            <div class="form-check form-switch fs-5">
                                <input class="form-check-input" type="checkbox" id="chkIsRequired" checked style="cursor:pointer;">
                                <label class="form-check-label ms-2 fs-6">Zorunlu Soru</label>
                            </div>
                        </div>
                    </div>

                    <div id="optionsArea" style="display:none;" class="p-3 bg-light border rounded-4">
                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <label class="form-label fw-bold mb-0 text-primary"><i class="fa fa-list-ul me-2"></i>Seçenekler ve Akıllı Atlama</label>
                            <button type="button" class="btn btn-sm btn-success rounded-pill px-3" id="btnAddOption">
                                <i class="fa fa-plus me-1"></i> Şık Ekle
                            </button>
                        </div>
                        <div id="optionsContainer">
                            <!-- Şıklar buraya gelecek -->
                        </div>
                        <div class="small text-muted mt-2">
                            <i class="fa-solid fa-circle-info me-1"></i> "Hedef Soru", bu şık seçildiğinde kullanıcının atlayacağı soruyu belirler.
                        </div>
                    </div>
                </form>
            </div>
            <div class="modal-footer border-0 bg-light rounded-bottom-4">
                <button type="button" class="btn btn-secondary px-4 rounded-pill" data-bs-dismiss="modal">İptal</button>
                <button type="button" class="btn btn-primary px-5 rounded-pill fw-bold shadow" id="btnSaveQuestion">Kaydet</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        var allQuestions = [];
        var surveyId = $("#hdnSurveyId").val();

        function getToken() { return localStorage.getItem("token"); }

        $(document).ready(function () {
            loadQuestions();

            function loadQuestions() {
                $.ajax({
                    url: "https://localhost:7094/api/Question/GetBySurvey/" + surveyId,
                    type: "GET",
                    headers: { "Authorization": "Bearer " + getToken() },
                    success: function (res) {
                        allQuestions = res.data || res.Data || [];
                        var html = "";

                        if (allQuestions.length > 0) {
                            allQuestions.forEach(function (q, index) {
                                var qId = q.id || q.Id;
                                var qText = q.text || q.Text || "Soru";
                                var qType = q.type !== undefined ? q.type : q.Type;
                                var isReq = q.isRequired !== undefined ? q.isRequired : q.IsRequired;
                                var mUrl = q.mediaUrl || q.MediaUrl;

                                var typeIcon = qType == 1 ? "fa-align-left" : (qType == 2 ? "fa-circle-dot" : "fa-square-check");
                                var requiredBadge = isReq ? '<span class="badge bg-danger ms-2">Zorunlu</span>' : '';

                                html += `
                                <div class="p-4 border-bottom question-item">
                                    <div class="d-flex justify-content-between align-items-start">
                                        <div class="flex-grow-1">
                                            <h5 class="fw-bold mb-1">${index + 1}. ${qText} ${requiredBadge}</h5>
                                            <span class="small text-muted"><i class="fa-solid ${typeIcon} me-1"></i> ${qType==1?'Metin':qType==2?'Tek Seçim':'Çoklu Seçim'}</span>
                                        </div>
                                        <div class="ms-3 d-flex">
                                            <button class="btn btn-sm btn-light border btn-edit-question me-1" data-id="${qId}" title="Düzenle"><i class="fa fa-pen text-warning"></i></button>
                                            <button class="btn btn-sm btn-light border btn-delete-question" data-id="${qId}" title="Sil"><i class="fa fa-trash text-danger"></i></button>
                                        </div>
                                    </div>
                                    ${mUrl ? `<div class="mt-2"><small class="text-truncate d-block" style="max-width:300px"><i class="fa fa-link me-1"></i>${mUrl}</small></div>` : ''}
                                </div>`;
                            });
                        } else {
                            html = '<div class="text-center p-5 text-muted">Henüz soru eklenmemiş. "Yeni Soru Ekle" butonu ile başlayın.</div>';
                        }
                        $("#questionsList").html(html);
                    }
                });
            }

            // KRİTİK DÜZELTME: Dropdown'a soruları doldururken sigortalı değişkenler
            function addOptionInput(text = "", img = "", nextQId = null) {
                var skipOptions = `<option value="">Sıradaki Soru (Varsayılan)</option>`;
                allQuestions.forEach(function(item) {
                    var itemId = item.id || item.Id; // Sigorta!
                    var itemText = item.text || item.Text || "Soru"; // Sigorta!

                    var selected = (nextQId && nextQId == itemId) ? "selected" : "";
                    skipOptions += `<option value="${itemId}" ${selected}>${itemText.substring(0, 40)}...</option>`;
                });

                var html = `
                    <div class="option-row bg-white border rounded-3 p-3 mb-3 shadow-sm">
                        <div class="row g-2">
                            <div class="col-md-7">
                                <label class="small fw-bold text-muted mb-1">Şık Metni</label>
                                <input type="text" class="form-control form-control-sm option-input" placeholder="Seçenek metni..." value="${text}">
                            </div>
                            <div class="col-md-5 text-end">
                                <button class="btn btn-sm btn-link text-danger btn-remove-option mt-3 p-0" type="button"><i class="fa fa-trash me-1"></i>Sil</button>
                            </div>
                            <div class="col-md-6">
                                <label class="small fw-bold text-muted mb-1">Görsel URL (Opsiyonel)</label>
                                <input type="text" class="form-control form-control-sm option-image-input" placeholder="https://..." value="${img}">
                            </div>
                            <div class="col-md-6">
                                <label class="small fw-bold text-primary mb-1"><i class="fa-solid fa-shuffle me-1"></i>Hedef Soru (Skip Logic)</label>
                                <select class="form-select form-select-sm next-question-select">
                                    ${skipOptions}
                                </select>
                            </div>
                        </div>
                    </div>`;
                $("#optionsContainer").append(html);
            }

            $("#btnOpenAddModal").click(function () {
                $("#hdnQuestionId").val("0");
                $("#modalTitle").text("Yeni Soru Ekle");
                $("#frmQuestion")[0].reset();
                $("#optionsArea").hide();
                $("#optionsContainer").empty();
                $("#questionModal").modal("show");
            });

            $(document).on("click", ".btn-edit-question", function () {
                var id = $(this).data("id");
                var q = allQuestions.find(x => (x.id || x.Id) == id);
                if (q) {
                    $("#hdnQuestionId").val(q.id || q.Id);
                    $("#modalTitle").text("Soruyu Düzenle");
                    $("#txtQuestionText").val(q.text || q.Text);
                    $("#txtMediaUrl").val(q.mediaUrl || q.MediaUrl || "");

                    var qType = q.type !== undefined ? q.type : q.Type;
                    $("#cbQuestionType").val(qType);
                    $("#chkIsRequired").prop("checked", q.isRequired !== undefined ? q.isRequired : q.IsRequired);
                    $("#optionsContainer").empty();

                    if (qType != 1) {
                        $("#optionsArea").show();
                        var opts = q.options || q.Options || [];
                        opts.forEach(opt => {
                            var nqId = opt.nextQuestionId || opt.NextQuestionId || null;
                            addOptionInput(opt.optionText || opt.OptionText, opt.imageUrl || opt.ImageUrl, nqId);
                        });
                    }
                    $("#questionModal").modal("show");
                }
            });

            $("#cbQuestionType").change(function () {
                if ($(this).val() == "1") { $("#optionsArea").hide(); $("#optionsContainer").empty(); }
                else {
                    $("#optionsArea").show();
                    if ($("#optionsContainer .option-row").length === 0) {
                        addOptionInput(); addOptionInput();
                    }
                }
            });

            $("#btnAddOption").click(function() { addOptionInput(); });
            $(document).on("click", ".btn-remove-option", function () { $(this).closest(".option-row").remove(); });

            $("#btnSaveQuestion").click(function () {
                var qId = parseInt($("#hdnQuestionId").val());
                var options = [];

                if ($("#cbQuestionType").val() != "1") {
                    $(".option-row").each(function (i) {
                        var txt = $(this).find(".option-input").val().trim();
                        var img = $(this).find(".option-image-input").val().trim();
                        var nextQ = $(this).find(".next-question-select").val();

                        if (txt !== "") {
                            // KRİTİK DÜZELTME: Undefined koruması
                            var finalNextId = (nextQ && nextQ !== "" && nextQ !== "undefined") ? parseInt(nextQ) : null;

                            options.push({
                                OptionText: txt,
                                ImageUrl: img,
                                Order: i + 1,
                                NextQuestionId: finalNextId
                            });
                        }
                    });
                }

                var payload = {
                    Id: qId,
                    SurveyId: parseInt(surveyId),
                    Text: $("#txtQuestionText").val(),
                    MediaUrl: $("#txtMediaUrl").val(),
                    Type: parseInt($("#cbQuestionType").val()),
                    IsRequired: $("#chkIsRequired").is(":checked"),
                    Options: options
                };

                var url = qId > 0 ? "https://localhost:7094/api/Question/UpdateQuestion" : "https://localhost:7094/api/Question/AddQuestion";

                $.ajax({
                    url: url,
                    type: qId > 0 ? "PUT" : "POST",
                    contentType: "application/json",
                    headers: { "Authorization": "Bearer " + getToken() },
                    data: JSON.stringify(payload),
                    success: function (res) {
                        if (res.status || res.Status) {
                            $("#questionModal").modal("hide");
                            Swal.fire("Başarılı", "Soru başarıyla kaydedildi.", "success");
                            loadQuestions();
                        }
                    }
                });
            });

            $(document).on("click", ".btn-delete-question", function () {
                var id = $(this).data("id");
                Swal.fire({ title: 'Soru silinsin mi?', text: "Bu soruya verilen tüm cevaplar da silinecektir!", icon: 'warning', showCancelButton: true, confirmButtonText: 'Evet, Sil' }).then((result) => {
                    if (result.isConfirmed) {
                        $.ajax({
                            url: "https://localhost:7094/api/Question/" + id,
                            type: "DELETE",
                            headers: { "Authorization": "Bearer " + getToken() },
                            success: function () {
                                Swal.fire("Silindi", "Soru kaldırıldı.", "success");
                                loadQuestions();
                            }
                        });
                    }
                });
            });
        });
    </script>
    <style>
        .question-item:hover {
            background-color: #f8f9fc;
        }

        .border-left-primary {
            border-left: 4px solid #4e73df !important;
        }

        .border-left-info {
            border-left: 4px solid #36b9cc !important;
        }

        .option-row {
            transition: all 0.2s;
        }

            .option-row:hover {
                border-color: #4e73df !important;
            }
    </style>
}
