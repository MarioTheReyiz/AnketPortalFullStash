@{
    ViewData["Title"] = "Anket Soruları";
    var surveyId = ViewContext.RouteData.Values["id"];
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="h4 text-gray-800"><i class="fa-solid fa-list-check text-primary me-2"></i> Soru Yönetimi</h2>
        <div>
            <a href="/Survey/Index" class="btn btn-outline-secondary btn-sm me-2"><i class="fa fa-arrow-left"></i> Geri Dön</a>
            <button class="btn btn-primary btn-sm" id="btnOpenAddModal">
                <i class="fa fa-plus"></i> Yeni Soru Ekle
            </button>
        </div>
    </div>

    <div class="card shadow border-left-primary">
        <div class="card-body" id="questionsList">
            <div class="text-center p-5">
                <i class="fas fa-spinner fa-spin fa-2x text-primary mb-2"></i><br>
                Sorular Yükleniyor...
            </div>
        </div>
    </div>
</div>

<!-- MODAL -->
<div class="modal fade" id="questionModal" tabindex="-1" data-bs-backdrop="static">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header bg-primary text-white">
                <h5 class="modal-title" id="modalTitle">Yeni Soru Ekle</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <form id="frmQuestion" onsubmit="return false;">
                    <input type="hidden" id="hdnSurveyId" value="@surveyId" />
                    <input type="hidden" id="hdnQuestionId" value="0" />

                    <div class="mb-3">
                        <label class="form-label fw-bold">Soru Metni</label>
                        <input type="text" class="form-control" id="txtQuestionText" placeholder="Sorduğunuz soruyu buraya yazın..." required>
                    </div>

                    <div class="mb-3">
                        <label class="form-label small text-muted fw-bold">Soru Görsel/Video URL (Opsiyonel)</label>
                        <input type="text" class="form-control form-control-sm" id="txtMediaUrl" placeholder="https://... (Resim veya YouTube linki)">
                    </div>

                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label class="form-label fw-bold">Soru Tipi</label>
                            <select class="form-select" id="cbQuestionType">
                                <option value="1">Kısa Metin (Açık Uçlu)</option>
                                <option value="2">Tek Seçim (Radio Button)</option>
                                <option value="3">Çoklu Seçim (Checkbox)</option>
                            </select>
                        </div>
                        <div class="col-md-6 d-flex align-items-end pb-1">
                            <div class="form-check form-switch fs-5">
                                <input class="form-check-input" type="checkbox" id="chkIsRequired" checked style="cursor:pointer;">
                                <label class="form-check-label ms-2 fs-6">Bu soru zorunlu mu?</label>
                            </div>
                        </div>
                    </div>

                    <div id="optionsArea" style="display:none;" class="p-3 bg-light border rounded text-center">
                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <label class="form-label fw-bold mb-0 text-primary"><i class="fa fa-list"></i> Şıklar ve Görselleri</label>
                            <button type="button" class="btn btn-sm btn-success" id="btnAddOption">
                                <i class="fa fa-plus"></i> Şık Ekle
                            </button>
                        </div>
                        <div id="optionsContainer"></div>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">İptal</button>
                <button type="button" class="btn btn-primary" id="btnSaveQuestion">Kaydet</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        var allQuestions = [];
        var token = localStorage.getItem("token");

        $(document).ready(function () {
            loadQuestions();

            function loadQuestions() {
                var surveyId = $("#hdnSurveyId").val();
                $.ajax({
                    url: "https://localhost:7094/api/Question/GetBySurvey/" + surveyId,
                    type: "GET",
                    headers: { "Authorization": "Bearer " + token },
                    success: function (res) {
                        if (res.status) {
                            // KRİTİK DÜZELTME: Büyük/Küçük harf duyarlılığını ortadan kaldırıyoruz
                            allQuestions = res.data || res.Data || [];
                            var html = "";

                            if (allQuestions.length > 0) {
                                allQuestions.forEach(function (q, index) {
                                    var typeName = q.type == 1 ? "Metin" : (q.type == 2 ? "Radio" : "Checkbox");
                                    var requiredBadge = q.isRequired ? '<span class="badge bg-danger ms-2">Zorunlu</span>' : '';

                                    html += `
                                    <div class="card mb-4 shadow-sm border-left-info">
                                        <div class="card-body">
                                            <div class="d-flex justify-content-between align-items-start">
                                                <div>
                                                    <h5 class="fw-bold mb-1">${index + 1}. ${q.text} ${requiredBadge}</h5>
                                                    <span class="badge bg-secondary mb-2">${typeName}</span>
                                                </div>
                                                <div>
                                                    <button class="btn btn-sm btn-outline-warning btn-edit-question me-1" data-id="${q.id}"><i class="fa fa-pen"></i></button>
                                                    <button class="btn btn-sm btn-outline-danger btn-delete-question" data-id="${q.id}"><i class="fa fa-trash"></i></button>
                                                </div>
                                            </div>`;

                                    if (q.mediaUrl) {
                                        if (q.mediaUrl.includes("youtube.com") || q.mediaUrl.includes("youtu.be")) {
                                            var vidId = q.mediaUrl.includes('v=') ? q.mediaUrl.split('v=')[1].split('&')[0] : q.mediaUrl.split('/').pop();
                                            html += `<div class="ratio ratio-16x9 my-3 shadow-sm rounded overflow-hidden" style="max-width:450px">
                                                        <iframe src="https://www.youtube.com/embed/${vidId}" allowfullscreen></iframe>
                                                     </div>`;
                                        } else {
                                            html += `<img src="${q.mediaUrl}" class="img-fluid rounded my-3 shadow-sm border" style="max-height:250px; display:block;">`;
                                        }
                                    }

                                    if (q.type != 1) {
                                        html += `<div class="row row-cols-1 row-cols-md-2 g-2 mt-2">`;
                                        // options/Options kontrolü eklendi
                                        var opts = q.options || q.Options || [];
                                        opts.forEach(opt => {
                                            var imgTag = opt.imageUrl ? `<img src="${opt.imageUrl}" class="rounded me-2 shadow-sm" style="width:35px;height:35px;object-fit:cover;border:1px solid #eee;">` : `<i class="fa-regular fa-circle text-muted me-2"></i>`;
                                            html += `<div class="col"><div class="p-2 border rounded bg-white d-flex align-items-center">${imgTag} <span class="small">${opt.optionText}</span></div></div>`;
                                        });
                                        html += `</div>`;
                                    }
                                    html += `</div></div>`;
                                });
                            } else {
                                html = '<p class="text-center text-muted my-5">Bu ankete henüz soru eklenmemiş.</p>';
                            }
                            $("#questionsList").html(html);
                        }
                    },
                    error: function(xhr) {
                        console.error("Yükleme Hatası:", xhr.status, xhr.responseText);
                        $("#questionsList").html('<div class="alert alert-danger text-center">Sorular yüklenirken bir hata oluştu. (Hata: ' + xhr.status + ')</div>');
                    }
                });
            }

            $("#btnOpenAddModal").click(function () {
                $("#hdnQuestionId").val("0");
                $("#modalTitle").text("Yeni Soru Ekle");
                $("#frmQuestion")[0].reset();
                $("#optionsArea").hide();
                $("#optionsContainer").empty();
                $("#questionModal").modal("show");
            });

            $(document).on("click", ".btn-edit-question", function () {
                var id = $(this).data("id");
                var q = allQuestions.find(x => x.id == id);
                if (q) {
                    $("#hdnQuestionId").val(q.id);
                    $("#modalTitle").text("Soruyu Düzenle");
                    $("#txtQuestionText").val(q.text);
                    $("#txtMediaUrl").val(q.mediaUrl || "");
                    $("#cbQuestionType").val(q.type);
                    $("#chkIsRequired").prop("checked", q.isRequired);
                    $("#optionsContainer").empty();
                    if (q.type != 1) {
                        $("#optionsArea").show();
                        var opts = q.options || q.Options || [];
                        opts.forEach(opt => addOptionInput(opt.optionText, opt.imageUrl));
                    }
                    $("#questionModal").modal("show");
                }
            });

            $("#cbQuestionType").change(function () {
                if ($(this).val() == "1") { $("#optionsArea").hide(); $("#optionsContainer").empty(); }
                else { $("#optionsArea").show(); if ($("#optionsContainer .option-row").length === 0) { addOptionInput(); addOptionInput(); } }
            });

            $("#btnAddOption").click(function() { addOptionInput(); });

            function addOptionInput(text = "", img = "") {
                var html = `
                    <div class="option-row border rounded p-2 mb-2 bg-white shadow-sm">
                        <div class="input-group mb-1">
                            <input type="text" class="form-control form-control-sm option-input" placeholder="Şık metni..." value="${text}">
                            <button class="btn btn-sm btn-outline-danger btn-remove-option" type="button"><i class="fa fa-trash"></i></button>
                        </div>
                        <input type="text" class="form-control form-control-sm option-image-input" placeholder="Görsel URL (Opsiyonel)" value="${img || ""}">
                    </div>`;
                $("#optionsContainer").append(html);
            }

            $(document).on("click", ".btn-remove-option", function () { $(this).closest(".option-row").remove(); });

            $("#btnSaveQuestion").click(function () {
                var qId = parseInt($("#hdnQuestionId").val());
                var options = [];
                if ($("#cbQuestionType").val() != "1") {
                    $(".option-row").each(function (i) {
                        var txt = $(this).find(".option-input").val().trim();
                        var img = $(this).find(".option-image-input").val().trim();
                        if (txt !== "") options.push({ OptionText: txt, ImageUrl: img, Order: i + 1 });
                    });
                }

                var payload = {
                    Id: qId,
                    SurveyId: parseInt($("#hdnSurveyId").val()),
                    Text: $("#txtQuestionText").val(),
                    MediaUrl: $("#txtMediaUrl").val(),
                    Type: parseInt($("#cbQuestionType").val()),
                    IsRequired: $("#chkIsRequired").is(":checked"),
                    Options: options
                };

                var method = qId > 0 ? "PUT" : "POST";
                var url = qId > 0 ? "https://localhost:7094/api/Question/UpdateQuestion" : "https://localhost:7094/api/Question/AddQuestion";

                $.ajax({
                    url: url,
                    type: method,
                    contentType: "application/json",
                    headers: { "Authorization": "Bearer " + token },
                    data: JSON.stringify(payload),
                    success: function (res) {
                        if (res.status) {
                            $("#questionModal").modal("hide");
                            Swal.fire("Başarılı", res.message, "success");
                            loadQuestions();
                        }
                    }
                });
            });

            $(document).on("click", ".btn-delete-question", function () {
                var id = $(this).data("id");
                Swal.fire({ title: 'Emin misiniz?', icon: 'warning', showCancelButton: true, confirmButtonText: 'Sil' }).then((result) => {
                    if (result.isConfirmed) {
                        $.ajax({
                            url: "https://localhost:7094/api/Question/" + id,
                            type: "DELETE",
                            headers: { "Authorization": "Bearer " + token },
                            success: function () { loadQuestions(); }
                        });
                    }
                });
            });
        });
    </script>
}