@{
    ViewData["Title"] = "Anket Yönetimi";
}

<div class="card shadow mb-4 border-bottom-primary">
    <div class="card-header py-3 d-flex justify-content-between align-items-center">
        <h6 class="m-0 font-weight-bold text-primary"><i class="fa-solid fa-list me-2"></i>Sistemdeki Anketler</h6>
        <button class="btn btn-sm btn-success fw-bold" id="btnNewSurvey">
            <i class="fa-solid fa-plus me-1"></i> Yeni Anket Oluştur
        </button>
    </div>
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-bordered table-hover align-middle" id="surveyTable" width="100%" cellspacing="0">
                <thead class="table-light">
                    <tr>
                        <th style="width: 50px;">ID</th>
                        <th>Anket Başlığı</th>
                        <th>Bitiş Tarihi</th>
                        <th class="text-center">Görünürlük</th>
                        <th class="text-center">Durum</th>
                        <th class="text-center" style="width: 180px;">İşlemler</th>
                    </tr>
                </thead>
                <tbody id="surveyTableBody">
                    <tr>
                        <td colspan="6" class="text-center text-muted p-4">
                            <i class="fas fa-spinner fa-spin fa-2x mb-2"></i><br>
                            Anketler Yükleniyor...
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- 1. Yeni Anket Ekleme Modalı -->
<div class="modal fade" id="newSurveyModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header bg-success text-white">
                <h5 class="modal-title fw-bold"><i class="fa-solid fa-plus me-2"></i>Yeni Anket Oluştur</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <form id="frmAddSurvey" onsubmit="return false;">
                    <div class="mb-3">
                        <label class="form-label fw-bold">Anket Başlığı <span class="text-danger">*</span></label>
                        <input type="text" class="form-control" id="txtTitle" placeholder="Anket başlığını girin..." required>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold">Açıklama</label>
                        <textarea class="form-control" id="txtDescription" rows="3" placeholder="Anket amacını yazın..."></textarea>
                    </div>
                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label class="form-label fw-bold">Görünürlük</label>
                            <select class="form-select border-info" id="cmbIsPublic">
                                <option value="true">🌐 Herkese Açık</option>
                                <option value="false">🔗 Sadece Link İle</option>
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-bold">Bitiş Tarihi <span class="text-danger">*</span></label>
                            <input type="datetime-local" class="form-control" id="txtEndDate" required>
                        </div>
                    </div>
                    <div class="mb-3 p-3 bg-light rounded text-center border">
                        <label class="form-label fw-bold mb-2 d-block">Yayın Durumu</label>
                        <div class="d-flex align-items-center justify-content-center">
                            <span class="text-secondary fw-bold me-3">Pasif</span>
                            <div class="form-check form-switch m-0 p-0">
                                <input class="form-check-input m-0" type="checkbox" id="chkNewIsActive" style="cursor:pointer; width: 3em; height: 1.5em;" checked>
                            </div>
                            <span class="text-success fw-bold ms-3">Aktif</span>
                        </div>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">İptal</button>
                <button type="button" class="btn btn-success fw-bold" id="btnSaveSurvey">Kaydet</button>
            </div>
        </div>
    </div>
</div>

<!-- 2. Anket Düzenleme Modalı -->
<div class="modal fade" id="editSurveyModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header bg-warning text-dark">
                <h5 class="modal-title fw-bold"><i class="fa-solid fa-pen me-2"></i>Anketi Düzenle</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <form id="frmEditSurvey" onsubmit="return false;">
                    <input type="hidden" id="txtEditId">
                    <div class="mb-3">
                        <label class="form-label fw-bold">Anket Başlığı <span class="text-danger">*</span></label>
                        <input type="text" class="form-control" id="txtEditTitle" required>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold">Açıklama</label>
                        <textarea class="form-control" id="txtEditDescription" rows="3"></textarea>
                    </div>
                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label class="form-label fw-bold">Görünürlük</label>
                            <select class="form-select border-info" id="cmbEditIsPublic">
                                <option value="true">🌐 Herkese Açık</option>
                                <option value="false">🔗 Sadece Link İle</option>
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-bold">Bitiş Tarihi <span class="text-danger">*</span></label>
                            <input type="datetime-local" class="form-control" id="txtEditEndDate" required>
                        </div>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">İptal</button>
                <button type="button" class="btn btn-warning fw-bold" id="btnUpdateSurvey">Güncelle</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            LoadSurveys();

            // Yeni Anket Modalı Hazırlığı
            $("#btnNewSurvey").click(function () {
                $("#frmAddSurvey")[0].reset();
                var now = new Date();
                var minDate = new Date(now.getTime() - now.getTimezoneOffset() * 60000).toISOString().slice(0, 16);
                $("#txtEndDate").attr("min", minDate);

                var tomorrow = new Date(now.getTime() + (24 * 60 * 60 * 1000));
                tomorrow.setMinutes(tomorrow.getMinutes() - tomorrow.getTimezoneOffset());
                $("#txtEndDate").val(tomorrow.toISOString().slice(0, 16));

                $("#newSurveyModal").modal("show");
            });

            // Kaydet (POST)
            $("#btnSaveSurvey").click(function () {
                var payload = {
                    Title: $("#txtTitle").val().trim(),
                    Description: $("#txtDescription").val().trim(),
                    EndDate: $("#txtEndDate").val(),
                    IsActive: $("#chkNewIsActive").is(":checked"),
                    IsPublic: $("#cmbIsPublic").val() === "true"
                };

                if (!payload.Title || !payload.EndDate) {
                    Swal.fire('Uyarı', 'Lütfen gerekli alanları doldurun.', 'warning');
                    return;
                }

                $.ajax({
                    url: "https://localhost:7094/api/Survey",
                    type: "POST",
                    contentType: "application/json",
                    headers: { "Authorization": "Bearer " + localStorage.getItem("token") },
                    data: JSON.stringify(payload),
                    success: function (res) {
                        if (res.status) {
                            $("#newSurveyModal").modal("hide");
                            Swal.fire('Başarılı', res.message, 'success');
                            LoadSurveys();
                        }
                    }
                });
            });

            // Silme (DELETE)
            $(document).on("click", ".btn-delete", function () {
                var id = $(this).data("id");
                Swal.fire({
                    title: 'Emin misiniz?',
                    text: "Anket ve içindeki tüm sorular silinecek!",
                    icon: 'warning',
                    showCancelButton: true,
                    confirmButtonText: 'Evet, Sil!',
                    cancelButtonText: 'İptal'
                }).then((result) => {
                    if (result.isConfirmed) {
                        $.ajax({
                            url: "https://localhost:7094/api/Survey/" + id + "/HardDelete",
                            type: "DELETE",
                            headers: { "Authorization": "Bearer " + localStorage.getItem("token") },
                            success: function () {
                                Swal.fire('Silindi', 'Anket kaldırıldı.', 'success');
                                LoadSurveys();
                            }
                        });
                    }
                });
            });

            // Düzenleme Modalı Aç (Veri Doldurma)
            $(document).on("click", ".btn-edit", function () {
                var btn = $(this);
                $("#txtEditId").val(btn.data("id"));
                $("#txtEditTitle").val(btn.data("title"));
                $("#txtEditDescription").val(btn.data("desc"));
                $("#cmbEditIsPublic").val(btn.data("public").toString());

                // Tarih formatlama
                var rawDate = btn.data("date");
                if(rawDate) {
                    var date = new Date(rawDate);
                    date.setMinutes(date.getMinutes() - date.getTimezoneOffset());
                    $("#txtEditEndDate").val(date.toISOString().slice(0, 16));
                }

                $("#editSurveyModal").modal("show");
            });

            // Güncelleme (PUT)
            $("#btnUpdateSurvey").click(function () {
                var payload = {
                    Id: parseInt($("#txtEditId").val()),
                    Title: $("#txtEditTitle").val().trim(),
                    Description: $("#txtEditDescription").val().trim(),
                    EndDate: $("#txtEditEndDate").val(),
                    IsPublic: $("#cmbEditIsPublic").val() === "true"
                };

                $.ajax({
                    url: "https://localhost:7094/api/Survey",
                    type: "PUT",
                    contentType: "application/json",
                    headers: { "Authorization": "Bearer " + localStorage.getItem("token") },
                    data: JSON.stringify(payload),
                    success: function (res) {
                        $("#editSurveyModal").modal("hide");
                        Swal.fire('Güncellendi', 'Değişiklikler kaydedildi.', 'success');
                        LoadSurveys();
                    }
                });
            });

            // Durum Değiştirme (Switch)
            $(document).on("change", ".status-toggle", function () {
                var id = $(this).data("id");
                var self = $(this);
                $.ajax({
                    url: "https://localhost:7094/api/Survey/ToggleActive/" + id,
                    type: "PUT",
                    headers: { "Authorization": "Bearer " + localStorage.getItem("token") },
                    error: function () {
                        self.prop("checked", !self.is(":checked"));
                        Swal.fire('Hata', 'Durum değiştirilemedi.', 'error');
                    }
                });
            });

            // Listeleme Fonksiyonu
            function LoadSurveys() {
                $.ajax({
                    url: "https://localhost:7094/api/Survey",
                    type: "GET",
                    headers: { "Authorization": "Bearer " + localStorage.getItem("token") },
                    success: function (surveys) {
                        var tbody = $("#surveyTableBody").empty();
                        if (surveys.length === 0) {
                            tbody.append('<tr><td colspan="6" class="text-center">Henüz anket yok.</td></tr>');
                            return;
                        }

                        $.each(surveys, function (i, s) {
                            var dateObj = new Date(s.endDate);
                            var dateStr = s.endDate.startsWith("0001") ? "Süresiz" : dateObj.toLocaleString('tr-TR');
                            var publicBadge = s.isPublic ? '<span class="badge bg-info text-dark">Herkese Açık</span>' : '<span class="badge bg-dark">Sadece Link</span>';
                            var statusSwitch = `<div class="form-check form-switch d-flex justify-content-center">
                                <input class="form-check-input status-toggle" type="checkbox" style="width:2.5em;height:1.2em;cursor:pointer;" data-id="${s.id}" ${s.isActive ? "checked" : ""}>
                            </div>`;

                            tbody.append(`
                                <tr>
                                    <td>${s.id}</td>
                                    <td class="fw-bold">${s.title}</td>
                                    <td>${dateStr}</td>
                                    <td class="text-center">${publicBadge}</td>
                                    <td>${statusSwitch}</td>
                                    <td class="text-center">
                                        <a href="/Survey/Detail/${s.id}" class="btn btn-sm btn-primary shadow-sm" title="Soruları Yönet"><i class="fa-solid fa-gear"></i></a>
                                        <button class="btn btn-sm btn-warning btn-edit ms-1" data-id="${s.id}" data-title="${s.title}" data-desc="${s.description || ''}" data-public="${s.isPublic}" data-date="${s.endDate}"><i class="fa-solid fa-pen"></i></button>
                                        <button class="btn btn-sm btn-danger btn-delete ms-1" data-id="${s.id}"><i class="fa-solid fa-trash"></i></button>
                                    </td>
                                </tr>`);
                        });
                    }
                });
            }
        });
    </script>
}